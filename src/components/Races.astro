---
import { races } from '../data/races';
---
<section id="epreuves" class="border-t border-[color:var(--color-line-soft)]"
  style="padding: clamp(48px, 8vw, 80px) clamp(20px, 4vw, 80px) clamp(72px, 12vw, 120px);">

  <!-- Header -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-7 lg:gap-15 items-baseline mb-10 lg:mb-15"
       style="margin-bottom: clamp(40px, 6vw, 60px);">
    <div>
      <div class="mono-label mb-5">— §01 / LES ÉPREUVES</div>
      <h2 class="h2-med">Cinq départs.<br/><span class="italic opacity-75">Un seul territoire.</span></h2>
    </div>
    <p class="max-w-[460px] text-[15px] sm:text-[17px] leading-[1.55] opacity-75 m-0" style="text-wrap: pretty;">
      Du Défi de Copilos à la Tectokids, chacune et chacun trouve sa boucle. Tout se court en fin d'après-midi — arrivée avant la tombée de la nuit.
    </p>
  </div>

  <!-- Selector — horizontal scroll mobile, 5-col grid desktop -->
  <div id="race-carousel"
       class="flex lg:grid lg:grid-cols-5 gap-3 lg:gap-px overflow-x-auto lg:overflow-visible snap-x snap-mandatory scrollbar-hide -mx-5 px-5 lg:mx-0 lg:px-0"
       style="background: transparent;">
    {races.map((race, i) => (
      <button
        class="race-card group text-left cursor-pointer flex-shrink-0 w-[220px] lg:w-auto snap-start transition-colors duration-200"
        data-race-index={i}
        data-gpx={race.gpx}
        data-has-loops={race.loops ? 'true' : 'false'}
        style={`padding: 24px 20px; border: 1px solid var(--color-line); background: ${i === 0 ? 'var(--color-accent)' : 'var(--color-bg)'}; color: ${i === 0 ? 'var(--color-bg)' : 'var(--color-ink)'}; font-family: inherit;`}
      >
        <div class="mb-5 text-[10px] sm:text-[11px] tracking-[0.22em] opacity-65" style="font-family: var(--font-mono);">
          {race.roman} / {race.title}
        </div>
        <div class="flex items-baseline gap-1 mb-3">
          <span style="font-family: var(--font-serif); font-size: clamp(36px, 4.5vw, 44px); line-height: 0.9;">{race.dist}</span>
          <span class="text-[10px] sm:text-[11px] tracking-[0.15em] opacity-70" style="font-family: var(--font-mono);">{race.unit}</span>
        </div>
        <div class="flex gap-[3px] mt-3">
          {Array.from({ length: 5 }).map((_, n) => (
            <span class="race-diff-bar" data-filled={n < race.diff ? '1' : '0'} style="width: 14px; height: 3px; display: block;"></span>
          ))}
        </div>
      </button>
    ))}
  </div>

  <!-- Details area: map + details panel -->
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-8 lg:gap-16 items-start"
       style="margin-top: clamp(32px, 5vw, 64px);">
    <!-- Left: map + stats + elevation -->
    <div>
      <!-- Stats single -->
      <div id="stats-single" class="flex flex-wrap gap-x-5 gap-y-2 mb-4 text-[12px]" style="font-family: var(--font-mono);">
        <div><span class="opacity-60">DIST </span><span id="stat-distance" class="text-[color:var(--color-accent)]">—</span></div>
        <div><span class="opacity-60">D+ </span><span id="stat-ascent" class="text-[color:var(--color-accent)]">—</span></div>
        <div><span class="opacity-60">D− </span><span id="stat-descent" class="text-[color:var(--color-accent)]">—</span></div>
        <div><span class="opacity-60">ALT MIN </span><span id="stat-min-ele" class="text-[color:var(--color-accent)]">—</span></div>
        <div><span class="opacity-60">ALT MAX </span><span id="stat-max-ele" class="text-[color:var(--color-accent)]">—</span></div>
      </div>

      <!-- Stats multi -->
      <div id="stats-multi" class="hidden mb-4">
        <div class="flex flex-wrap gap-x-5 gap-y-2 mb-3 text-[12px]" style="font-family: var(--font-mono);">
          <div><span class="opacity-60">TOTAL </span><span id="stat-total-distance" class="text-[color:var(--color-accent)]">—</span></div>
          <div><span class="opacity-60">D+ </span><span id="stat-total-ascent" class="text-[color:var(--color-accent)]">—</span></div>
          <div><span class="opacity-60">D− </span><span id="stat-total-descent" class="text-[color:var(--color-accent)]">—</span></div>
          <div><span class="opacity-60">ALT MIN </span><span id="stat-total-min-ele" class="text-[color:var(--color-accent)]">—</span></div>
          <div><span class="opacity-60">ALT MAX </span><span id="stat-total-max-ele" class="text-[color:var(--color-accent)]">—</span></div>
        </div>
        <div id="loop-chips" class="flex flex-wrap gap-2"></div>
      </div>

      <!-- Map -->
      <div class="overflow-hidden border border-[color:var(--color-line)]">
        <div id="race-map" class="map-container"></div>
      </div>

      <!-- Elevation -->
      <div class="mt-4 border border-[color:var(--color-line)] p-4 sm:p-5" style="background: var(--color-bg-elev);">
        <p class="text-[10px] tracking-[0.22em] opacity-60 mb-3" style="font-family: var(--font-mono);">PROFIL ALTIMÉTRIQUE</p>
        <div class="elevation-container">
          <canvas id="elevation-chart"></canvas>
        </div>
      </div>
    </div>

    <!-- Right: race info (one panel per race, toggled) -->
    <div>
      {races.map((race, i) => (
        <div class:list={['race-info', i === 0 ? '' : 'hidden']} data-info-index={i}>
          <div class="mono-label mb-5">{race.roman} / {race.title}</div>
          <h3 class="mb-5" style="font-family: var(--font-serif); font-weight: 400; line-height: 0.95; letter-spacing: -0.025em; font-size: clamp(44px, 5vw, 68px); margin: 0 0 20px;">
            <em style="font-style: italic;">{race.type}</em>
          </h3>
          <p class="text-[15px] sm:text-[17px] leading-[1.55] opacity-85 m-0" style="text-wrap: pretty;">{race.desc}</p>

          <!-- Key facts grid -->
          <div class="grid grid-cols-3 gap-px mt-8 border border-[color:var(--color-line)]" style="background: var(--color-line);">
            <div class="p-4 sm:p-5" style="background: var(--color-bg);">
              <div class="text-[9px] tracking-[0.22em] opacity-50 mb-1.5" style="font-family: var(--font-mono);">DISTANCE</div>
              <div class="text-[color:var(--color-accent)]" style="font-family: var(--font-serif); font-size: clamp(20px, 2.2vw, 28px);">{race.dist} {race.unit.toLowerCase()}</div>
            </div>
            <div class="p-4 sm:p-5" style="background: var(--color-bg);">
              <div class="text-[9px] tracking-[0.22em] opacity-50 mb-1.5" style="font-family: var(--font-mono);">D+</div>
              <div class="text-[color:var(--color-accent)]" style="font-family: var(--font-serif); font-size: clamp(20px, 2.2vw, 28px);">{race.dplus === '—' ? '—' : `${race.dplus} m`}</div>
            </div>
            <div class="p-4 sm:p-5" style="background: var(--color-bg);">
              <div class="text-[9px] tracking-[0.22em] opacity-50 mb-1.5" style="font-family: var(--font-mono);">DÉPART</div>
              <div class="text-[color:var(--color-accent)]" style="font-family: var(--font-serif); font-size: clamp(20px, 2.2vw, 28px);">{race.startTime}</div>
            </div>
          </div>

          {race.loops && (
            <div class="mt-8">
              <div class="text-[10px] tracking-[0.3em] opacity-50 mb-3" style="font-family: var(--font-mono);">QUATRE BOUCLES · QUATRE VALEURS</div>
              {race.loops.map((loop) => (
                <div class="grid items-baseline py-2.5 border-t border-[color:var(--color-line-soft)]" style="grid-template-columns: 40px 1fr auto auto; gap: 12px;">
                  <span class="text-[color:var(--color-accent)]" style="font-family: var(--font-serif); font-style: italic; font-size: clamp(18px, 1.8vw, 22px);">{loop.roman}</span>
                  <span class="text-[13px] sm:text-[15px] italic">« {loop.label} »</span>
                  <span class="text-[10px] sm:text-[11px] opacity-70" style="font-family: var(--font-mono);">{loop.distance} · {loop.ascent}</span>
                  <span class="hidden sm:inline text-[11px] opacity-70" style="font-family: var(--font-mono);">lim. {loop.timeLimit}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .race-card .race-diff-bar[data-filled="1"] { background: var(--color-accent); }
  .race-card .race-diff-bar[data-filled="0"] { background: rgba(232,227,211,0.15); }
  /* When card is active (gold bg), flip diff bars */
  .race-card.is-active .race-diff-bar[data-filled="1"] { background: var(--color-bg); }
  .race-card.is-active .race-diff-bar[data-filled="0"] { background: rgba(15,20,18,0.2); }
  .race-card:not(.is-active):hover {
    background: rgba(212,165,116,0.05) !important;
  }
</style>

<script>
  import { parseGPX, parseMultiTrackGPX, type TrackData } from '../scripts/gpx-parser';
  import { initMap, initMultiLoopMap, type MultiLoopMapResult } from '../scripts/map';
  import { initElevationChart, updateElevationChart } from '../scripts/elevation';
  import { races as racesData } from '../data/races';

  const cards = document.querySelectorAll('.race-card');
  const carousel = document.getElementById('race-carousel')!;
  const infoPanels = document.querySelectorAll('.race-info');
  const mapContainer = document.getElementById('race-map')!;
  const canvas = document.getElementById('elevation-chart') as HTMLCanvasElement;
  const statsSingle = document.getElementById('stats-single')!;
  const statsMulti = document.getElementById('stats-multi')!;
  const loopChips = document.getElementById('loop-chips')!;

  // Mark initial active card
  (cards[0] as HTMLElement).classList.add('is-active');

  let currentMap: ReturnType<typeof initMap> | null = null;
  let currentMultiMap: MultiLoopMapResult | null = null;
  let currentChart: any = null;
  let activeIndex = 0;
  let activeLoopIndex = 0;
  const loopTrackDataCache: Record<number, TrackData[]> = {};
  const allTrackData: TrackData[] = [];

  function resolveUrl(path: string): string {
    const base = import.meta.env.BASE_URL;
    return base.endsWith('/') ? base + path.replace(/^\//, '') : base + path;
  }

  async function preloadAll() {
    const gpxUrls = Array.from(cards).map(card => (card as HTMLElement).dataset.gpx!);
    const results = await Promise.all(gpxUrls.map(url => parseGPX(resolveUrl(url))));
    results.forEach((data, i) => { allTrackData[i] = data; });
    showRace(0);
  }

  function fmtKm(v: number) { return `${v.toFixed(1)} km`; }
  function fmtM(v: number) { return `${Math.round(v)} m`; }

  function showStatsSingle(data: TrackData) {
    document.getElementById('stat-distance')!.textContent = fmtKm(data.totalDistance);
    document.getElementById('stat-ascent')!.textContent = fmtM(data.totalAscent);
    document.getElementById('stat-descent')!.textContent = fmtM(data.totalDescent);
    document.getElementById('stat-min-ele')!.textContent = fmtM(data.minEle);
    document.getElementById('stat-max-ele')!.textContent = fmtM(data.maxEle);
  }

  function showStatsMultiTotal(loopData: TrackData[]) {
    const totalDist = loopData.reduce((s, d) => s + d.totalDistance, 0);
    const totalAsc = loopData.reduce((s, d) => s + d.totalAscent, 0);
    const totalDesc = loopData.reduce((s, d) => s + d.totalDescent, 0);
    const minEle = Math.min(...loopData.map(d => d.minEle));
    const maxEle = Math.max(...loopData.map(d => d.maxEle));
    document.getElementById('stat-total-distance')!.textContent = fmtKm(totalDist);
    document.getElementById('stat-total-ascent')!.textContent = fmtM(totalAsc);
    document.getElementById('stat-total-descent')!.textContent = fmtM(totalDesc);
    document.getElementById('stat-total-min-ele')!.textContent = fmtM(minEle);
    document.getElementById('stat-total-max-ele')!.textContent = fmtM(maxEle);
  }

  function buildLoopChips(raceIndex: number, loopTrackData: TrackData[]) {
    const race = racesData[raceIndex];
    if (!race.loops) return;
    loopChips.innerHTML = '';
    race.loops.forEach((loop, i) => {
      const data = loopTrackData[i];
      const chip = document.createElement('button');
      chip.className = 'loop-chip flex items-center gap-2 px-3 py-2 border text-[11px] cursor-pointer transition-colors';
      chip.dataset.loopIndex = String(i);
      chip.style.fontFamily = 'var(--font-mono)';
      chip.style.background = i === 0 ? 'rgba(212,165,116,0.08)' : 'var(--color-bg-elev)';
      chip.style.borderColor = i === 0 ? 'var(--color-accent)' : 'var(--color-line)';
      chip.style.color = 'var(--color-ink)';
      chip.innerHTML = `
        <span style="width: 18px; height: 18px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 700; color: #0f1412; background: ${loop.color};">${i + 1}</span>
        <span>${fmtKm(data.totalDistance)}</span>
        <span style="color: var(--color-accent);">↗ ${Math.round(data.totalAscent)}</span>
        <span class="hidden sm:inline opacity-60">lim. ${loop.timeLimit}</span>
      `;
      chip.addEventListener('click', () => selectLoop(raceIndex, i, loopTrackData));
      loopChips.appendChild(chip);
    });
  }

  function updateChipStyles(activeLoop: number) {
    loopChips.querySelectorAll('.loop-chip').forEach((chip, i) => {
      const el = chip as HTMLElement;
      el.style.background = i === activeLoop ? 'rgba(212,165,116,0.08)' : 'var(--color-bg-elev)';
      el.style.borderColor = i === activeLoop ? 'var(--color-accent)' : 'var(--color-line)';
    });
  }

  function updateCardStyles(selectedIndex: number) {
    cards.forEach((card, i) => {
      const el = card as HTMLElement;
      const isActive = i === selectedIndex;
      el.classList.toggle('is-active', isActive);
      el.style.background = isActive ? 'var(--color-accent)' : 'var(--color-bg)';
      el.style.color = isActive ? 'var(--color-bg)' : 'var(--color-ink)';
    });
    infoPanels.forEach((panel, i) => {
      panel.classList.toggle('hidden', i !== selectedIndex);
    });
  }

  function selectLoop(raceIndex: number, loopIndex: number, loopTrackData: TrackData[]) {
    activeLoopIndex = loopIndex;
    updateChipStyles(loopIndex);
    if (currentMultiMap) currentMultiMap.setActiveLoop(loopIndex);
    if (currentChart) {
      updateElevationChart(currentChart, loopTrackData[loopIndex], (index) => {
        currentMultiMap?.setMarkerAt(index);
      });
    }
  }

  function cleanupMap() {
    if (currentMap) { currentMap.map.remove(); currentMap = null; }
    if (currentMultiMap) { currentMultiMap.map.remove(); currentMultiMap = null; }
    if (currentChart) { currentChart.destroy(); currentChart = null; }
  }

  async function showRace(raceIndex: number) {
    cleanupMap();
    updateCardStyles(raceIndex);
    const race = racesData[raceIndex];

    if (race.loops) {
      statsSingle.classList.add('hidden');
      statsMulti.classList.remove('hidden');
      if (!loopTrackDataCache[raceIndex]) {
        loopTrackDataCache[raceIndex] = await parseMultiTrackGPX(resolveUrl(race.gpx));
      }
      const loopTrackData = loopTrackDataCache[raceIndex];
      const colors = race.loops.map(l => l.color);
      showStatsMultiTotal(loopTrackData);
      buildLoopChips(raceIndex, loopTrackData);
      activeLoopIndex = 0;
      currentMultiMap = initMultiLoopMap(mapContainer, loopTrackData, colors, 0);
      currentChart = initElevationChart(canvas, loopTrackData[0], (index) => {
        currentMultiMap?.setMarkerAt(index);
      });
      mapContainer.addEventListener('loopchange', ((e: CustomEvent) => {
        selectLoop(raceIndex, e.detail.index, loopTrackData);
      }) as EventListener);
    } else {
      statsSingle.classList.remove('hidden');
      statsMulti.classList.add('hidden');
      const trackData = allTrackData[raceIndex];
      showStatsSingle(trackData);
      currentMap = initMap(mapContainer, trackData);
      currentChart = initElevationChart(canvas, trackData, (index) => {
        currentMap?.setMarkerAt(index);
      });
    }
  }

  const CAROUSEL_BREAKPOINT = 1024;

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const el = card as HTMLElement;
      const index = parseInt(el.dataset.raceIndex!);
      if (index === activeIndex) return;
      activeIndex = index;
      showRace(index);
      if (window.innerWidth < CAROUSEL_BREAKPOINT) {
        el.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
    });
  });

  let scrollTimeout: number;
  carousel.addEventListener('scroll', () => {
    if (window.innerWidth >= CAROUSEL_BREAKPOINT) return;
    clearTimeout(scrollTimeout);
    scrollTimeout = window.setTimeout(() => {
      const carouselRect = carousel.getBoundingClientRect();
      const carouselCenter = carouselRect.left + carouselRect.width / 2;
      let closestIndex = 0;
      let closestDist = Infinity;
      cards.forEach((card, i) => {
        const rect = (card as HTMLElement).getBoundingClientRect();
        const cardCenter = rect.left + rect.width / 2;
        const dist = Math.abs(cardCenter - carouselCenter);
        if (dist < closestDist) { closestDist = dist; closestIndex = i; }
      });
      if (closestIndex !== activeIndex) {
        activeIndex = closestIndex;
        showRace(closestIndex);
      }
    }, 100);
  }, { passive: true });

  preloadAll();
</script>
