---
import { races } from '../data/races';
---
<section id="epreuves" class="relative py-20 sm:py-28 bg-cream grain-overlay">
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Storytelling header -->
    <div class="text-center mb-16">
      <p class="text-terracotta uppercase tracking-[0.25em] text-xs font-medium mb-4">L'héritage des Volques Tectosages</p>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-charcoal mb-6">
        Les traileurs sont-ils les<br/>descendants des Tectosages&nbsp;?
      </h2>
      <p class="text-clay max-w-2xl mx-auto text-sm sm:text-base leading-relaxed mb-4">
        Il y a 2300 ans, Vieille-Toulouse était la capitale du peuple des Volques Tectosages.
        Leurs valeurs — <span class="text-terracotta font-medium">l'esprit de conquête, le courage, la bravoure, l'honneur</span> —
        résonnent encore aujourd'hui dans l'âme des coureurs.
      </p>
      <p class="text-moss text-sm italic">
        Partez à la conquête du territoire de Tolosa — choisissez votre épreuve.
      </p>
    </div>

    <!-- Visual race selector -->
    <div
      id="race-carousel"
      class="flex lg:grid lg:grid-cols-5 gap-3 sm:gap-4 mb-6 lg:mb-12 overflow-x-auto lg:overflow-visible snap-x snap-mandatory scroll-smooth scrollbar-hide px-4 lg:px-0 -mx-4 lg:mx-0"
    >
      {races.map((race, i) => (
        <button
          class:list={[
            'race-card group relative text-left bg-linen border rounded-xl p-4 sm:p-5 transition-all duration-300 cursor-pointer lg:hover:-translate-y-1 snap-center lg:snap-align-none flex-shrink-0 w-[78%] sm:w-[55%] md:w-[38%] lg:w-auto',
            i === 0
              ? 'border-moss/60 shadow-md shadow-moss/15'
              : 'border-charcoal/10 lg:hover:border-moss/40',
          ]}
          data-race-index={i}
          data-gpx={race.gpx}
          data-has-loops={race.loops ? 'true' : 'false'}
        >
          <div class="text-3xl sm:text-4xl mb-3">{race.icon}</div>
          <p class="text-terracotta text-[10px] sm:text-xs uppercase tracking-wider mb-1 font-medium leading-tight">{race.type}</p>
          <h3 class="font-serif text-base sm:text-lg font-bold text-charcoal mb-2 leading-tight">{race.title}</h3>
          <p class="text-moss font-serif text-xl sm:text-2xl font-bold">{race.distance}</p>
          {race.ascent && <p class="text-clay text-xs mt-1">↗ {race.ascent}</p>}
        </button>
      ))}
    </div>

    <!-- Pagination dots -->
    <div id="race-dots" class="flex justify-center gap-2 mb-10 lg:hidden">
      {races.map((_, i) => (
        <button
          class:list={[
            'race-dot h-2 rounded-full transition-all duration-300 cursor-pointer',
            i === 0 ? 'w-6 bg-moss' : 'w-2 bg-charcoal/20',
          ]}
          data-dot-index={i}
          aria-label={`Aller à l'épreuve ${i + 1}`}
        ></button>
      ))}
    </div>

    <!-- Selected race details -->
    <div class="mb-8">
      {races.map((race, i) => (
        <div
          class:list={['race-info', i === 0 ? '' : 'hidden']}
          data-info-index={i}
        >
          <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-2 mb-3">
            <div>
              <p class="text-terracotta text-xs uppercase tracking-wider">{race.type}</p>
              <h3 class="font-serif text-2xl sm:text-3xl font-bold text-charcoal">{race.title}</h3>
            </div>
            <div class="text-right">
              <span class="text-moss font-serif text-3xl sm:text-4xl font-bold">{race.distance}</span>
              {race.ascent && <p class="text-clay text-xs mt-1">↗ {race.ascent}</p>}
            </div>
          </div>
          <p class="text-clay text-sm max-w-2xl leading-relaxed mb-3">{race.desc}</p>
          <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-clay">
            <span>🕐 Départ {race.startTime}</span>
            {race.duration && <span>· {race.duration}</span>}
            <span>· {race.timed ? 'Chronométré' : 'Non chronométré'}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Stats bar (single race) -->
    <div id="stats-single" class="flex flex-wrap gap-x-6 gap-y-2 text-sm mb-6 px-1">
      <div><span class="text-clay">Distance </span><span class="text-moss font-semibold" id="stat-distance">—</span></div>
      <div><span class="text-clay">D+ </span><span class="text-moss font-semibold" id="stat-ascent">—</span></div>
      <div><span class="text-clay">D− </span><span class="text-moss font-semibold" id="stat-descent">—</span></div>
      <div><span class="text-clay">Alt. min </span><span class="text-moss font-semibold" id="stat-min-ele">—</span></div>
      <div><span class="text-clay">Alt. max </span><span class="text-moss font-semibold" id="stat-max-ele">—</span></div>
    </div>

    <!-- Stats bar (multi-loop race) — total + per-segment -->
    <div id="stats-multi" class="hidden mb-6 px-1">
      <!-- Total line -->
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm mb-3">
        <div><span class="text-clay">Total </span><span class="text-moss font-semibold" id="stat-total-distance">—</span></div>
        <div><span class="text-clay">D+ </span><span class="text-moss font-semibold" id="stat-total-ascent">—</span></div>
        <div><span class="text-clay">D− </span><span class="text-moss font-semibold" id="stat-total-descent">—</span></div>
        <div><span class="text-clay">Alt. min </span><span class="text-moss font-semibold" id="stat-total-min-ele">—</span></div>
        <div><span class="text-clay">Alt. max </span><span class="text-moss font-semibold" id="stat-total-max-ele">—</span></div>
      </div>
      <!-- Segment chips -->
      <div id="loop-chips" class="flex flex-wrap gap-2">
        <!-- Populated dynamically -->
      </div>
    </div>

    <!-- Map -->
    <div class="rounded-xl overflow-hidden border border-charcoal/10 mb-6 shadow-sm">
      <div id="race-map" class="map-container"></div>
    </div>

    <!-- Elevation -->
    <div class="bg-linen border border-charcoal/10 rounded-xl p-4 sm:p-6 shadow-sm">
      <p class="text-moss text-xs uppercase tracking-wider mb-3 font-medium">Profil altimétrique</p>
      <div class="elevation-container">
        <canvas id="elevation-chart"></canvas>
      </div>
    </div>
  </div>
</section>

<script>
  import { parseGPX, parseMultiTrackGPX, type TrackData } from '../scripts/gpx-parser';
  import { initMap, initMultiLoopMap, type MultiLoopMapResult } from '../scripts/map';
  import { initElevationChart, updateElevationChart } from '../scripts/elevation';
  import { races as racesData } from '../data/races';

  const cards = document.querySelectorAll('.race-card');
  const dots = document.querySelectorAll('.race-dot');
  const carousel = document.getElementById('race-carousel')!;
  const infoPanels = document.querySelectorAll('.race-info');
  const mapContainer = document.getElementById('race-map')!;
  const canvas = document.getElementById('elevation-chart') as HTMLCanvasElement;
  const statsSingle = document.getElementById('stats-single')!;
  const statsMulti = document.getElementById('stats-multi')!;
  const loopChips = document.getElementById('loop-chips')!;

  let currentMap: ReturnType<typeof initMap> | null = null;
  let currentMultiMap: MultiLoopMapResult | null = null;
  let currentChart: any = null;
  let activeIndex = 0;
  let activeLoopIndex = 0;

  const loopTrackDataCache: Record<number, TrackData[]> = {};

  function resolveUrl(path: string): string {
    const base = import.meta.env.BASE_URL;
    return base.endsWith('/') ? base + path.replace(/^\//, '') : base + path;
  }

  const allTrackData: TrackData[] = [];

  async function preloadAll() {
    const gpxUrls = Array.from(cards).map(card => (card as HTMLElement).dataset.gpx!);
    const results = await Promise.all(gpxUrls.map(url => parseGPX(resolveUrl(url))));
    results.forEach((data, i) => { allTrackData[i] = data; });
    showRace(0);
  }

  function showStatsSingle(data: TrackData) {
    document.getElementById('stat-distance')!.textContent = `${data.totalDistance.toFixed(1)} km`;
    document.getElementById('stat-ascent')!.textContent = `${Math.round(data.totalAscent)} m`;
    document.getElementById('stat-descent')!.textContent = `${Math.round(data.totalDescent)} m`;
    document.getElementById('stat-min-ele')!.textContent = `${Math.round(data.minEle)} m`;
    document.getElementById('stat-max-ele')!.textContent = `${Math.round(data.maxEle)} m`;
  }

  function showStatsMultiTotal(loopData: TrackData[]) {
    const totalDist = loopData.reduce((s, d) => s + d.totalDistance, 0);
    const totalAsc = loopData.reduce((s, d) => s + d.totalAscent, 0);
    const totalDesc = loopData.reduce((s, d) => s + d.totalDescent, 0);
    const minEle = Math.min(...loopData.map(d => d.minEle));
    const maxEle = Math.max(...loopData.map(d => d.maxEle));

    document.getElementById('stat-total-distance')!.textContent = `${totalDist.toFixed(1)} km`;
    document.getElementById('stat-total-ascent')!.textContent = `${Math.round(totalAsc)} m`;
    document.getElementById('stat-total-descent')!.textContent = `${Math.round(totalDesc)} m`;
    document.getElementById('stat-total-min-ele')!.textContent = `${Math.round(minEle)} m`;
    document.getElementById('stat-total-max-ele')!.textContent = `${Math.round(maxEle)} m`;
  }

  function buildLoopChips(raceIndex: number, loopTrackData: TrackData[]) {
    const race = racesData[raceIndex];
    if (!race.loops) return;

    loopChips.innerHTML = '';
    race.loops.forEach((loop, i) => {
      const data = loopTrackData[i];
      const isActive = i === 0;
      const chip = document.createElement('button');
      chip.className = `loop-chip flex items-center gap-2 px-3 py-2 rounded-lg border text-xs transition-all duration-300 cursor-pointer ${
        isActive ? 'border-moss/60 bg-moss/5' : 'border-charcoal/10 bg-linen hover:border-moss/30'
      }`;
      chip.dataset.loopIndex = String(i);

      chip.innerHTML = `
        <span class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold text-white flex-shrink-0" style="background: ${loop.color};">${i + 1}</span>
        <span class="text-charcoal font-medium">${data.totalDistance.toFixed(1)} km</span>
        <span class="text-moss">↗ ${Math.round(data.totalAscent)}</span>
        <span class="text-clay hidden sm:inline">⏱ ${loop.timeLimit}</span>
      `;

      chip.addEventListener('click', () => selectLoop(raceIndex, i, loopTrackData));
      loopChips.appendChild(chip);
    });
  }

  function updateChipStyles(activeLoop: number) {
    loopChips.querySelectorAll('.loop-chip').forEach((chip, i) => {
      if (i === activeLoop) {
        chip.classList.remove('border-charcoal/10', 'bg-linen');
        chip.classList.add('border-moss/60', 'bg-moss/5');
      } else {
        chip.classList.remove('border-moss/60', 'bg-moss/5');
        chip.classList.add('border-charcoal/10', 'bg-linen');
      }
    });
  }

  function updateCardStyles(selectedIndex: number) {
    cards.forEach((card, i) => {
      const el = card as HTMLElement;
      if (i === selectedIndex) {
        el.classList.remove('border-charcoal/10');
        el.classList.add('border-moss/60', 'shadow-md', 'shadow-moss/15');
      } else {
        el.classList.remove('border-moss/60', 'shadow-md', 'shadow-moss/15');
        el.classList.add('border-charcoal/10');
      }
    });
    dots.forEach((dot, i) => {
      const el = dot as HTMLElement;
      if (i === selectedIndex) {
        el.classList.remove('w-2', 'bg-charcoal/20');
        el.classList.add('w-6', 'bg-moss');
      } else {
        el.classList.remove('w-6', 'bg-moss');
        el.classList.add('w-2', 'bg-charcoal/20');
      }
    });
    infoPanels.forEach((panel, i) => {
      panel.classList.toggle('hidden', i !== selectedIndex);
    });
  }

  function selectLoop(raceIndex: number, loopIndex: number, loopTrackData: TrackData[]) {
    activeLoopIndex = loopIndex;
    updateChipStyles(loopIndex);

    if (currentMultiMap) {
      currentMultiMap.setActiveLoop(loopIndex);
    }

    // Animate transition to new elevation data
    if (currentChart) {
      updateElevationChart(currentChart, loopTrackData[loopIndex], (index) => {
        currentMultiMap?.setMarkerAt(index);
      });
    }
  }

  function cleanupMap() {
    if (currentMap) { currentMap.map.remove(); currentMap = null; }
    if (currentMultiMap) { currentMultiMap.map.remove(); currentMultiMap = null; }
    if (currentChart) { currentChart.destroy(); currentChart = null; }
  }

  async function showRace(raceIndex: number) {
    cleanupMap();
    updateCardStyles(raceIndex);

    const race = racesData[raceIndex];

    if (race.loops) {
      statsSingle.classList.add('hidden');
      statsMulti.classList.remove('hidden');

      if (!loopTrackDataCache[raceIndex]) {
        loopTrackDataCache[raceIndex] = await parseMultiTrackGPX(resolveUrl(race.gpx));
      }

      const loopTrackData = loopTrackDataCache[raceIndex];
      const colors = race.loops.map(l => l.color);

      showStatsMultiTotal(loopTrackData);
      buildLoopChips(raceIndex, loopTrackData);

      activeLoopIndex = 0;

      currentMultiMap = initMultiLoopMap(mapContainer, loopTrackData, colors, 0);
      currentChart = initElevationChart(canvas, loopTrackData[0], (index) => {
        currentMultiMap?.setMarkerAt(index);
      });

      mapContainer.addEventListener('loopchange', ((e: CustomEvent) => {
        selectLoop(raceIndex, e.detail.index, loopTrackData);
      }) as EventListener);
    } else {
      statsSingle.classList.remove('hidden');
      statsMulti.classList.add('hidden');

      const trackData = allTrackData[raceIndex];
      showStatsSingle(trackData);

      currentMap = initMap(mapContainer, trackData);
      currentChart = initElevationChart(canvas, trackData, (index) => {
        currentMap?.setMarkerAt(index);
      });
    }
  }

  const CAROUSEL_BREAKPOINT = 1024;

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const el = card as HTMLElement;
      const index = parseInt(el.dataset.raceIndex!);
      if (index === activeIndex) return;
      activeIndex = index;
      showRace(index);
      if (window.innerWidth < CAROUSEL_BREAKPOINT) {
        el.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
    });
  });

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = parseInt((dot as HTMLElement).dataset.dotIndex!);
      const card = cards[index] as HTMLElement;
      card.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      if (index !== activeIndex) {
        activeIndex = index;
        showRace(index);
      }
    });
  });

  let scrollTimeout: number;
  carousel.addEventListener('scroll', () => {
    if (window.innerWidth >= CAROUSEL_BREAKPOINT) return;
    clearTimeout(scrollTimeout);
    scrollTimeout = window.setTimeout(() => {
      const carouselRect = carousel.getBoundingClientRect();
      const carouselCenter = carouselRect.left + carouselRect.width / 2;
      let closestIndex = 0;
      let closestDist = Infinity;
      cards.forEach((card, i) => {
        const rect = (card as HTMLElement).getBoundingClientRect();
        const cardCenter = rect.left + rect.width / 2;
        const dist = Math.abs(cardCenter - carouselCenter);
        if (dist < closestDist) {
          closestDist = dist;
          closestIndex = i;
        }
      });
      if (closestIndex !== activeIndex) {
        activeIndex = closestIndex;
        showRace(closestIndex);
      }
    }, 100);
  }, { passive: true });

  preloadAll();
</script>
