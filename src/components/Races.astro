---
import { races } from '../data/races';
---
<section id="epreuves" class="border-t border-[color:var(--color-line-soft)]"
  style="padding: clamp(48px, 8vw, 80px) clamp(20px, 4vw, 80px) clamp(72px, 12vw, 120px);">

  <!-- Header -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-7 lg:gap-15 items-baseline mb-10 lg:mb-15"
       style="margin-bottom: clamp(40px, 6vw, 60px);">
    <div>
      <div class="mono-label mb-5">— §01 / LES ÉPREUVES</div>
      <h2 class="h2-med">Cinq départs.<br/><span class="italic opacity-75">Un seul territoire.</span></h2>
    </div>
    <p class="max-w-[460px] text-[15px] sm:text-[17px] leading-[1.55] opacity-75 m-0" style="text-wrap: pretty;">
      Du Défi de Copilos à la Tectokids, chacune et chacun trouve sa boucle. Tout se court en fin d'après-midi — arrivée avant la tombée de la nuit.
    </p>
  </div>

  <!-- Selector — horizontal scroll mobile, 5-col grid desktop -->
  <div id="race-carousel"
       class="flex lg:grid lg:grid-cols-5 gap-3 lg:gap-px overflow-x-auto lg:overflow-visible snap-x snap-mandatory scrollbar-hide -mx-5 px-5 lg:mx-0 lg:px-0"
       style="background: transparent;">
    {races.map((race, i) => (
      <button
        class="race-card group text-left cursor-pointer flex-shrink-0 w-[220px] lg:w-auto snap-start transition-colors duration-200"
        data-race-index={i}
        data-gpx={race.gpx}
        data-has-loops={race.loops ? 'true' : 'false'}
        style={`padding: 24px 20px; border: 1px solid var(--color-line); background: ${i === 0 ? 'var(--color-accent)' : 'var(--color-bg)'}; color: ${i === 0 ? 'var(--color-bg)' : 'var(--color-ink)'}; font-family: inherit;`}
      >
        <div class="mb-5 text-[10px] sm:text-[11px] tracking-[0.22em] opacity-65" style="font-family: var(--font-mono);">
          {race.roman} / {race.title}
        </div>
        <div class="flex items-baseline gap-1 mb-3">
          <span style="font-family: var(--font-serif); font-size: clamp(36px, 4.5vw, 44px); line-height: 0.9;">{race.dist}</span>
          <span class="text-[10px] sm:text-[11px] tracking-[0.15em] opacity-70" style="font-family: var(--font-mono);">{race.unit}</span>
        </div>
        <div class="flex gap-[3px] mt-3">
          {Array.from({ length: 5 }).map((_, n) => (
            <span class="race-diff-bar" data-filled={n < race.diff ? '1' : '0'} style="width: 14px; height: 3px; display: block;"></span>
          ))}
        </div>
      </button>
    ))}
  </div>

  <!-- Details area: map + details panel -->
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-8 lg:gap-16 items-start"
       style="margin-top: clamp(32px, 5vw, 64px);">

    <!-- Left: segment selector + map + elevation -->
    <div class="border border-[color:var(--color-line)]" style="background: var(--color-bg);">
      <!-- Segment selector (multi-loop only) -->
      <div id="segment-selector" class="hidden"></div>

      <!-- Map + overlays -->
      <div class="relative">
        <div id="race-map" class="map-container" style="height: 52vh; min-height: 320px; max-height: 540px; border: none;"></div>

        <!-- Stats overlay (top-left) -->
        <div id="map-stats" class="pointer-events-none"
             style="position: absolute; top: 14px; left: 14px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; color: var(--color-ink); opacity: 0.85; line-height: 1.8; text-shadow: 0 1px 3px rgba(0,0,0,0.8);">
          <div id="stats-label">TRACÉ COMPLET</div>
          <div id="stats-distance">—</div>
          <div id="stats-alt">—</div>
        </div>

        <!-- Compass (top-right) -->
        <div class="pointer-events-none"
             style="position: absolute; top: 14px; right: 14px; font-family: var(--font-mono); color: var(--color-ink); opacity: 0.6; text-align: center;">
          <div style="font-size: 11px; font-weight: 600; letter-spacing: 0.1em; line-height: 1;">N</div>
          <svg width="6" height="22" viewBox="0 0 6 22" style="margin-top: 4px; display: inline-block;">
            <line x1="3" y1="4" x2="3" y2="22" stroke="currentColor" stroke-width="1"/>
            <polygon points="3,2 0,9 6,9" fill="currentColor"/>
          </svg>
        </div>

        <!-- Hover tooltip (bottom-right) -->
        <div id="map-tooltip" class="pointer-events-none"
             style="position: absolute; bottom: 12px; right: 12px; display: none; background: var(--color-ink); color: var(--color-bg); padding: 8px 12px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; line-height: 1.6;"></div>
      </div>

      <!-- Elevation (SVG injected via script) -->
      <div id="elevation-chart"></div>
    </div>

    <!-- Right: race info (one panel per race, toggled) -->
    <div>
      {races.map((race, i) => (
        <div class:list={['race-info', i === 0 ? '' : 'hidden']} data-info-index={i}>
          <div class="mono-label mb-5">{race.roman} / {race.title}</div>
          <h3 class="mb-5" style="font-family: var(--font-serif); font-weight: 400; line-height: 0.95; letter-spacing: -0.025em; font-size: clamp(44px, 5vw, 68px); margin: 0 0 20px;">
            <em style="font-style: italic;">{race.type}</em>
          </h3>
          <p class="text-[15px] sm:text-[17px] leading-[1.55] opacity-85 m-0" style="text-wrap: pretty;">{race.desc}</p>

          <!-- Key facts grid -->
          <div class="grid grid-cols-3 gap-px mt-8 border border-[color:var(--color-line)]" style="background: var(--color-line);">
            <div class="p-4 sm:p-5" style="background: var(--color-bg);">
              <div class="text-[9px] tracking-[0.22em] opacity-50 mb-1.5" style="font-family: var(--font-mono);">DISTANCE</div>
              <div class="text-[color:var(--color-accent)]" style="font-family: var(--font-serif); font-size: clamp(20px, 2.2vw, 28px);">{race.dist} {race.unit.toLowerCase()}</div>
            </div>
            <div class="p-4 sm:p-5" style="background: var(--color-bg);">
              <div class="text-[9px] tracking-[0.22em] opacity-50 mb-1.5" style="font-family: var(--font-mono);">D+</div>
              <div class="text-[color:var(--color-accent)]" style="font-family: var(--font-serif); font-size: clamp(20px, 2.2vw, 28px);">{race.dplus === '—' ? '—' : `${race.dplus} m`}</div>
            </div>
            <div class="p-4 sm:p-5" style="background: var(--color-bg);">
              <div class="text-[9px] tracking-[0.22em] opacity-50 mb-1.5" style="font-family: var(--font-mono);">DÉPART</div>
              <div class="text-[color:var(--color-accent)]" style="font-family: var(--font-serif); font-size: clamp(20px, 2.2vw, 28px);">{race.startTime}</div>
            </div>
          </div>

          {race.loops && (
            <div class="mt-8">
              <div class="text-[10px] tracking-[0.3em] opacity-50 mb-3" style="font-family: var(--font-mono);">QUATRE BOUCLES · QUATRE VALEURS</div>
              {race.loops.map((loop) => (
                <div class="grid items-baseline py-2.5 border-t border-[color:var(--color-line-soft)]" style="grid-template-columns: 40px 1fr auto auto; gap: 12px;">
                  <span class="text-[color:var(--color-accent)]" style="font-family: var(--font-serif); font-style: italic; font-size: clamp(18px, 1.8vw, 22px);">{loop.roman}</span>
                  <span class="text-[13px] sm:text-[15px] italic">« {loop.label} »</span>
                  <span class="text-[10px] sm:text-[11px] opacity-70" style="font-family: var(--font-mono);">{loop.distance} · {loop.ascent}</span>
                  <span class="hidden sm:inline text-[11px] opacity-70" style="font-family: var(--font-mono);">lim. {loop.timeLimit}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .race-card .race-diff-bar[data-filled="1"] { background: var(--color-accent); }
  .race-card .race-diff-bar[data-filled="0"] { background: rgba(232,227,211,0.15); }
  .race-card.is-active .race-diff-bar[data-filled="1"] { background: var(--color-bg); }
  .race-card.is-active .race-diff-bar[data-filled="0"] { background: rgba(15,20,18,0.2); }
  .race-card:not(.is-active):hover { background: rgba(212,165,116,0.05) !important; }

  #segment-selector {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }
  #segment-selector.hidden { display: none; }
  #segment-selector > button:first-child { grid-column: 1 / -1; }
  @media (min-width: 720px) {
    #segment-selector { grid-template-columns: repeat(5, 1fr); }
    #segment-selector > button:first-child { grid-column: auto; }
  }
  #segment-selector button {
    padding: 12px 8px; min-width: 0;
    background: var(--color-bg); color: var(--color-ink);
    border: none; cursor: pointer;
    font-family: var(--font-mono);
    font-size: 10px; letter-spacing: 0.18em; font-weight: 600; line-height: 1.3;
    transition: background-color .2s ease;
    text-align: center;
  }
  #segment-selector button:hover { background: rgba(212, 165, 116, 0.06); }
  #segment-selector button.is-active {
    color: var(--color-bg);
  }
  #segment-selector .seg-sub {
    display: block;
    opacity: 0.7; font-size: 9px; margin-top: 3px; letter-spacing: 0.12em;
  }
</style>

<script>
  import { parseGPX, parseMultiTrackGPX, type TrackData } from '../scripts/gpx-parser';
  import { initMap, initMultiLoopMap, type MultiLoopMapResult, type SingleMapResult } from '../scripts/map';
  import { renderElevation, type ElevationHandle } from '../scripts/elevation';
  import { races as racesData } from '../data/races';

  const ROMAN = ['I', 'II', 'III', 'IV', 'V'];

  const cards = document.querySelectorAll('.race-card');
  const carousel = document.getElementById('race-carousel')!;
  const infoPanels = document.querySelectorAll('.race-info');
  const mapContainer = document.getElementById('race-map')!;
  const elevContainer = document.getElementById('elevation-chart')!;
  const segmentSelector = document.getElementById('segment-selector')!;
  const statsLabel = document.getElementById('stats-label')!;
  const statsDistance = document.getElementById('stats-distance')!;
  const statsAlt = document.getElementById('stats-alt')!;
  const mapTooltip = document.getElementById('map-tooltip')!;

  (cards[0] as HTMLElement).classList.add('is-active');

  let currentMap: SingleMapResult | MultiLoopMapResult | null = null;
  let currentElev: ElevationHandle | null = null;
  let activeIndex = 0;
  let currentLoopData: TrackData[] = [];
  let activeSeg: number | null = null;

  const loopTrackDataCache: Record<number, TrackData[]> = {};
  const allTrackData: TrackData[] = [];

  function resolveUrl(path: string): string {
    const base = import.meta.env.BASE_URL;
    return base.endsWith('/') ? base + path.replace(/^\//, '') : base + path;
  }

  function fmt1(v: number) { return v.toFixed(1); }
  function fmtI(v: number) { return String(Math.round(v)); }

  async function preloadAll() {
    const gpxUrls = Array.from(cards).map(card => (card as HTMLElement).dataset.gpx!);
    const results = await Promise.all(gpxUrls.map(url => parseGPX(resolveUrl(url))));
    results.forEach((data, i) => { allTrackData[i] = data; });
    showRace(0);
  }

  function updateCardStyles(selectedIndex: number) {
    cards.forEach((card, i) => {
      const el = card as HTMLElement;
      const isActive = i === selectedIndex;
      el.classList.toggle('is-active', isActive);
      el.style.background = isActive ? 'var(--color-accent)' : 'var(--color-bg)';
      el.style.color = isActive ? 'var(--color-bg)' : 'var(--color-ink)';
    });
    infoPanels.forEach((panel, i) => {
      panel.classList.toggle('hidden', i !== selectedIndex);
    });
  }

  function updateStatsOverlay() {
    const segs = currentLoopData;
    if (segs.length === 0) return;

    if (segs.length === 1) {
      const d = segs[0];
      statsLabel.textContent = 'TRACÉ';
      statsDistance.textContent = `${fmt1(d.totalDistance)} KM · +${fmtI(d.totalAscent)}M`;
      statsAlt.textContent = `ALT. ${fmtI(d.minEle)}–${fmtI(d.maxEle)} M`;
    } else if (activeSeg == null) {
      const totalDist = segs.reduce((s, d) => s + d.totalDistance, 0);
      const totalAsc = segs.reduce((s, d) => s + d.totalAscent, 0);
      const minEle = Math.min(...segs.map(d => d.minEle));
      const maxEle = Math.max(...segs.map(d => d.maxEle));
      statsLabel.textContent = 'TRACÉ COMPLET';
      statsDistance.textContent = `${fmt1(totalDist)} KM · +${fmtI(totalAsc)}M`;
      statsAlt.textContent = `ALT. ${fmtI(minEle)}–${fmtI(maxEle)} M`;
    } else {
      const d = segs[activeSeg];
      statsLabel.textContent = `BOUCLE ${ROMAN[activeSeg]}`;
      statsDistance.textContent = `${fmt1(d.totalDistance)} KM · +${fmtI(d.totalAscent)}M`;
      statsAlt.textContent = `ALT. ${fmtI(d.minEle)}–${fmtI(d.maxEle)} M`;
    }
  }

  function updateSegmentSelectorActive() {
    segmentSelector.querySelectorAll<HTMLButtonElement>('button').forEach((btn) => {
      const raw = btn.dataset.seg!;
      const segIdx = raw === 'all' ? null : parseInt(raw);
      const isActive = segIdx === activeSeg;
      btn.classList.toggle('is-active', isActive);
      if (isActive) {
        const color = btn.dataset.color || 'var(--color-ink)';
        btn.style.background = color;
      } else {
        btn.style.background = 'var(--color-bg)';
      }
    });
  }

  function buildSegmentSelector(raceIndex: number) {
    const race = racesData[raceIndex];
    segmentSelector.innerHTML = '';

    if (!race.loops) {
      segmentSelector.classList.add('hidden');
      return;
    }
    segmentSelector.classList.remove('hidden');

    // "Vue complète"
    const allBtn = document.createElement('button');
    allBtn.dataset.seg = 'all';
    allBtn.dataset.color = 'var(--color-ink)';
    allBtn.innerHTML = 'VUE COMPLÈTE';
    allBtn.style.color = 'var(--color-ink)'; // will be overridden by active state below
    allBtn.addEventListener('click', () => selectSeg(null));
    segmentSelector.appendChild(allBtn);

    // Per-loop buttons
    race.loops.forEach((loop, i) => {
      const btn = document.createElement('button');
      btn.dataset.seg = String(i);
      btn.dataset.color = loop.color;
      const distTxt = loop.distance.replace(/\s*km\s*$/i, '').trim();
      const ascTxt = loop.ascent.replace(/\s*m\s*$/i, '').trim();
      const sub = `${distTxt} KM · ${ascTxt}M`;
      btn.innerHTML = `BOUCLE ${ROMAN[i]}<span class="seg-sub">${sub}</span>`;
      btn.addEventListener('click', () => selectSeg(i));
      segmentSelector.appendChild(btn);
    });

    // Active color/text colors: when active, the text should be bg-colored (dark on gold/ink bg)
    segmentSelector.querySelectorAll<HTMLButtonElement>('button.is-active, button').forEach(btn => {
      // leave default; updateSegmentSelectorActive will handle it
    });

    // Inject the :is-active color rule via inline style — handled by update fn below
    const style = document.createElement('style');
    style.textContent = `#segment-selector button.is-active { color: var(--color-bg) !important; }`;
    if (!document.getElementById('seg-active-style')) {
      style.id = 'seg-active-style';
      document.head.appendChild(style);
    }
  }

  function selectSeg(i: number | null) {
    activeSeg = i;
    updateSegmentSelectorActive();
    updateStatsOverlay();

    if (currentMap && 'setActiveSeg' in currentMap) {
      (currentMap as MultiLoopMapResult).setActiveSeg(i);
    }
    if (currentElev) {
      currentElev.setActiveSeg(i);
    }
  }

  function onElevationHover(segIdx: number, ptIdx: number) {
    const seg = currentLoopData[segIdx];
    if (!seg) return;
    const pt = seg.points[ptIdx];
    if (!pt) return;

    mapTooltip.style.display = 'block';
    mapTooltip.textContent = `KM ${fmt1(pt.dist + segStartKmOffset(segIdx))} · ALT ${fmtI(pt.ele)} M`;

    if (currentMap) {
      if ('setMarkerAt' in currentMap) {
        if (currentLoopData.length > 1) {
          (currentMap as MultiLoopMapResult).setMarkerAt(segIdx, ptIdx);
        } else {
          (currentMap as SingleMapResult).setMarkerAt(ptIdx);
        }
      }
    }
  }

  function onElevationLeave() {
    mapTooltip.style.display = 'none';
    currentMap?.clearMarker?.();
  }

  function segStartKmOffset(segIdx: number): number {
    let acc = 0;
    for (let i = 0; i < segIdx; i++) acc += currentLoopData[i].totalDistance;
    return acc;
  }

  function cleanup() {
    if (currentMap) { currentMap.map.remove(); currentMap = null; }
    if (currentElev) { currentElev.destroy(); currentElev = null; }
    mapTooltip.style.display = 'none';
  }

  async function showRace(raceIndex: number) {
    cleanup();
    updateCardStyles(raceIndex);
    const race = racesData[raceIndex];

    if (race.loops) {
      if (!loopTrackDataCache[raceIndex]) {
        loopTrackDataCache[raceIndex] = await parseMultiTrackGPX(resolveUrl(race.gpx));
      }
      currentLoopData = loopTrackDataCache[raceIndex];
      const colors = race.loops.map(l => l.color);

      activeSeg = null;
      buildSegmentSelector(raceIndex);
      updateSegmentSelectorActive();
      updateStatsOverlay();

      currentMap = initMultiLoopMap(mapContainer, currentLoopData, colors, null);

      currentElev = renderElevation({
        container: elevContainer,
        segments: currentLoopData,
        segmentColors: colors,
        gpxHref: resolveUrl(race.gpx),
        activeSeg: null,
        onHover: onElevationHover,
        onLeave: onElevationLeave,
      });
    } else {
      currentLoopData = [allTrackData[raceIndex]];
      segmentSelector.classList.add('hidden');
      activeSeg = null;
      updateStatsOverlay();

      currentMap = initMap(mapContainer, currentLoopData[0]);

      currentElev = renderElevation({
        container: elevContainer,
        segments: currentLoopData,
        segmentColors: ['#d4a574'],
        gpxHref: resolveUrl(race.gpx),
        activeSeg: null,
        onHover: onElevationHover,
        onLeave: onElevationLeave,
      });
    }
  }

  const CAROUSEL_BREAKPOINT = 1024;

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const el = card as HTMLElement;
      const index = parseInt(el.dataset.raceIndex!);
      if (index === activeIndex) return;
      activeIndex = index;
      showRace(index);
      if (window.innerWidth < CAROUSEL_BREAKPOINT) {
        el.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
    });
  });

  let scrollTimeout: number;
  carousel.addEventListener('scroll', () => {
    if (window.innerWidth >= CAROUSEL_BREAKPOINT) return;
    clearTimeout(scrollTimeout);
    scrollTimeout = window.setTimeout(() => {
      const carouselRect = carousel.getBoundingClientRect();
      const carouselCenter = carouselRect.left + carouselRect.width / 2;
      let closestIndex = 0;
      let closestDist = Infinity;
      cards.forEach((card, i) => {
        const rect = (card as HTMLElement).getBoundingClientRect();
        const cardCenter = rect.left + rect.width / 2;
        const dist = Math.abs(cardCenter - carouselCenter);
        if (dist < closestDist) { closestDist = dist; closestIndex = i; }
      });
      if (closestIndex !== activeIndex) {
        activeIndex = closestIndex;
        showRace(closestIndex);
      }
    }, 100);
  }, { passive: true });

  preloadAll();
</script>
