---
import { withBase } from '../lib/url';

interface Props {
  data: {
    label: string;
    titleLine1: string;
    titleEmphasis: string;
    body: string;
    partners: { name: string; sub: string; logo: string }[];
  };
}
const { data } = Astro.props;
---
<section id="soutiens"
  class="border-t border-[color:var(--color-line-soft)]"
  style="background: var(--color-bg-deep); padding: clamp(56px, 8vw, 120px) clamp(20px, 4vw, 80px);">

  <div class="max-w-[780px]" style="margin-bottom: clamp(32px, 4vw, 56px);">
    <div class="mono-label mb-5">{data.label}</div>
    <h2 style="font-family: var(--font-serif); font-size: clamp(36px, 4vw, 56px); line-height: 1.05; font-weight: 400; margin: 0; letter-spacing: -0.025em;">
      {data.titleLine1}<br/><em style="color: var(--color-accent); font-style: italic;">{data.titleEmphasis}</em>.
    </h2>
    <p class="text-[14px] sm:text-[15px] leading-[1.6] opacity-70 m-0 max-w-[640px]"
       style="margin-top: 20px; text-wrap: pretty;">
      {data.body}
    </p>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-5 gap-px border border-[color:var(--color-line)]"
       style="background: var(--color-line);">
    {data.partners.map((p) => (
      <div class="flex flex-col items-center gap-3.5 partner-cell"
           style="background: var(--color-bg-deep); padding: clamp(20px, 2.5vw, 32px) clamp(14px, 2vw, 24px);">
        <div class="w-full flex items-center justify-center bg-white"
             style="aspect-ratio: 1.3 / 1; padding: 14px;">
          <img src={withBase(p.logo)} alt={`${p.name} ${p.sub}`}
               class="partner-logo"
               style="max-width: 100%; max-height: 100%; object-fit: contain; display: block;"
               onerror="this.closest('.partner-cell')?.classList.add('partner-missing');" />
        </div>
        <div class="text-[10px] tracking-[0.16em] opacity-75 text-center leading-[1.5]"
             style="font-family: var(--font-mono);">
          {p.name}<br/><span style="opacity: 0.7;">{p.sub}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .partner-cell.partner-missing .partner-logo { display: none; }
  .partner-cell.partner-missing > div:first-child::after {
    content: "";
    display: block;
    width: 50%;
    height: 2px;
    background: rgba(15, 20, 18, 0.15);
  }
</style>
