---
const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base}${base.endsWith('/') ? '' : '/'}${p.replace(/^\//, '')}`;
const lionsLogo = withBase('images/logo-lions.png');
const marieLouise = withBase('images/logo-marie-louise.png');
const golfLogo = withBase('images/logo-golf.png');
---
<footer
  class="border-t border-[color:var(--color-line-soft)]"
  style="background: var(--color-bg-deep); padding: clamp(36px, 5vw, 48px) clamp(20px, 4vw, 80px) clamp(24px, 3vw, 28px);">

  <!-- 4-column grid: Identity / Événement / Contact / Avec -->
  <div class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr_1fr_1fr] items-start"
       style="gap: clamp(32px, 4vw, 48px); margin-bottom: clamp(32px, 4vw, 40px);">

    <!-- Col 1 — Identity -->
    <div>
      <div class="flex items-center gap-3 mb-4">
        <span class="flex items-center justify-center rounded-full border shrink-0"
              style="width: 30px; height: 30px; border-color: var(--color-accent); border-width: 1.5px; color: var(--color-accent); font-family: var(--font-serif); font-size: 14px; font-style: italic;">T</span>
        <span style="font-family: var(--font-serif); font-size: 20px; font-weight: 400;">
          Trail des <em style="color: var(--color-accent); font-style: italic;">Tectosages</em>
        </span>
      </div>
      <div class="text-[10px] tracking-[0.24em] opacity-55 mb-3.5" style="font-family: var(--font-mono);">
        ÉDITION I · 2026
      </div>
      <p class="text-[13px] leading-[1.55] opacity-65 m-0 max-w-[340px]" style="text-wrap: pretty;">
        Samedi 3 octobre 2026 · Vieille-Toulouse, Haute-Garonne.
      </p>
    </div>

    <!-- Col 2 — Événement -->
    <div>
      <div class="text-[10px] tracking-[0.26em] mb-4" style="font-family: var(--font-mono); color: var(--color-accent); opacity: 0.85;">
        ÉVÉNEMENT
      </div>
      <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
        <li><a href="#epreuves" class="footer-link">Les épreuves</a></li>
        <li><a href="#histoire" class="footer-link">L'histoire</a></li>
        <li><a href="#banquet"  class="footer-link">Le banquet</a></li>
        <li><a href="#" class="footer-link">Règlement</a></li>
        <li><a href="#" class="footer-link">FAQ</a></li>
      </ul>
    </div>

    <!-- Col 3 — Contact -->
    <div>
      <div class="text-[10px] tracking-[0.26em] mb-4" style="font-family: var(--font-mono); color: var(--color-accent); opacity: 0.85;">
        CONTACT
      </div>
      <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
        <li><a href="mailto:contact@tectosages.fr" class="footer-link">contact@tectosages.fr</a></li>
        <li><a href="#" class="footer-link">Instagram</a></li>
        <li><a href="#" class="footer-link">Presse &amp; médias</a></li>
      </ul>
    </div>

    <!-- Col 4 — Avec (partenaires) -->
    <div>
      <div class="text-[10px] tracking-[0.26em] mb-4" style="font-family: var(--font-mono); color: var(--color-accent); opacity: 0.85;">
        AVEC
      </div>
      <div class="flex flex-wrap items-center gap-2.5">
        <div class="logo-tile" style="padding: 6px; border-radius: 2px;">
          <img src={lionsLogo} alt="Lions Club Toulouse Arènes Romaines"
               style="height: 42px; object-fit: contain; display: block;" />
        </div>
        <div class="logo-tile" style="padding: 6px; border-radius: 2px;">
          <img src={marieLouise} alt="Fondation Marie-Louise"
               style="height: 42px; object-fit: contain; display: block;" />
        </div>
        <div class="logo-tile" style="padding: 6px; border-radius: 2px;" id="footer-golf-tile">
          <img src={golfLogo} alt="Golf de Vieille-Toulouse"
               style="height: 42px; object-fit: contain; display: block;"
               onerror="this.closest('#footer-golf-tile')?.remove();" />
        </div>
      </div>
      <div class="text-[10px] tracking-[0.16em] opacity-50 mt-3 leading-[1.6]" style="font-family: var(--font-mono);">
        Lions Club Toulouse Arènes Romaines<br/>
        Fondation Marie-Louise<br/>
        Golf de Vieille-Toulouse
      </div>
    </div>
  </div>

  <!-- Bottom legal line -->
  <div class="flex flex-col lg:flex-row lg:justify-between lg:items-center gap-2.5 lg:gap-5 text-[10px] tracking-[0.2em] opacity-45"
       style="font-family: var(--font-mono); padding-top: clamp(20px, 2.5vw, 24px); border-top: 1px solid rgba(232,227,211,0.08);">
    <div>© 2026 · ASSOCIATION TRAIL DES TECTOSAGES</div>
    <div class="flex gap-6">
      <a href="#" class="no-underline" style="color: inherit;">MENTIONS LÉGALES</a>
      <a href="#" class="no-underline" style="color: inherit;">CGV</a>
      <a href="#" class="no-underline" style="color: inherit;">CONFIDENTIALITÉ</a>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    color: var(--color-ink);
    text-decoration: none;
    font-size: 13px;
    opacity: 0.8;
    transition: color 0.2s ease, opacity 0.2s ease;
  }
  .footer-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }
</style>
