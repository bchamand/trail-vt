---
import type { EventView } from '../lib/event';
import { withBase } from '../lib/url';

interface Props {
  event: EventView;
}
const { event } = Astro.props;
const { footer } = event;
// liens de route (commençant par /) → withBase ; ancres (#) et mailto inchangés
const linkHref = (h: string) => (h.startsWith('/') ? withBase(h) : h);
---
<footer
  class="border-t border-[color:var(--color-line-soft)]"
  style="background: var(--color-bg-deep); padding: clamp(40px, 5vw, 56px) clamp(20px, 4vw, 80px) clamp(24px, 3vw, 28px);">

  <!-- Marque à gauche · groupes de liens à droite (desktop) -->
  <div class="ft-top">

    <!-- Identité -->
    <div class="ft-brand">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex items-center justify-center rounded-full border shrink-0"
              style="width: 30px; height: 30px; border-color: var(--color-accent); border-width: 1.5px; color: var(--color-accent); font-family: var(--font-serif); font-size: 14px; font-style: italic;">{event.initial}</span>
        <span class="flex flex-col leading-none">
          <span style="font-family: var(--font-serif); font-size: 20px; font-weight: 400;">
            {event.nameShort} <em style="color: var(--color-accent); font-style: italic;">{event.nameEmphasis}</em>
          </span>
          <span class="text-[10px] mt-[5px] opacity-60 tracking-[0.24em]" style="font-family: var(--font-mono);">{event.locationCity}</span>
        </span>
      </div>
      <p class="text-[13px] leading-[1.55] opacity-65 m-0 max-w-[320px]" style="text-wrap: pretty;">
        {event.dateFull} · {event.location}
      </p>
    </div>

    <!-- Groupes de liens -->
    <div class="ft-cols">
      <div>
        <div class="ft-h">RESSOURCES</div>
        <ul class="ft-list">
          {footer.eventLinks.map(l => (
            <li><a href={linkHref(l.href)} class="footer-link">{l.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <div class="ft-h">CONTACT</div>
        <ul class="ft-list">
          {footer.contactLinks.map(l => (
            <li><a href={linkHref(l.href)} class="footer-link">{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bas de page · mentions légales -->
  <div class="ft-legal">
    <div>{footer.legal}</div>
    <div class="flex gap-6">
      {footer.legalLinks.map(l => (
        <a href={linkHref(l.href)} class="no-underline" style="color: inherit;">{l.label}</a>
      ))}
    </div>
  </div>
</footer>

<style>
  .ft-top {
    display: flex;
    flex-direction: column;
    gap: clamp(32px, 4vw, 44px);
    margin-bottom: clamp(32px, 4vw, 44px);
  }
  .ft-cols {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(40px, 7vw, 104px);
  }
  .ft-h {
    font-family: var(--font-mono);
    color: var(--color-accent);
    opacity: 0.85;
    font-size: 10px;
    letter-spacing: 0.26em;
    margin-bottom: 16px;
  }
  .ft-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-link {
    color: var(--color-ink);
    text-decoration: none;
    font-size: 13px;
    opacity: 0.8;
    transition: color 0.2s ease, opacity 0.2s ease;
  }
  .footer-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }
  .ft-legal {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: clamp(20px, 2.5vw, 24px);
    border-top: 1px solid rgba(232, 227, 211, 0.08);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    opacity: 0.45;
  }

  /* Tablette + desktop : marque à gauche, liens alignés à droite */
  @media (min-width: 768px) {
    .ft-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      gap: clamp(48px, 6vw, 120px);
    }
    .ft-cols {
      flex-wrap: nowrap;
      justify-content: flex-end;
    }
    .ft-legal {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
    }
  }
</style>
