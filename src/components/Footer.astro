---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/url';

interface Props {
  event: CollectionEntry<'event'>['data'];
}
const { event } = Astro.props;
const { footer } = event;
---
<footer
  class="border-t border-[color:var(--color-line-soft)]"
  style="background: var(--color-bg-deep); padding: clamp(36px, 5vw, 48px) clamp(20px, 4vw, 80px) clamp(24px, 3vw, 28px);">

  <div class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr_1fr_1fr] items-start"
       style="gap: clamp(32px, 4vw, 48px); margin-bottom: clamp(32px, 4vw, 40px);">

    <!-- Col 1 — Identity -->
    <div>
      <div class="flex items-center gap-3 mb-4">
        <span class="flex items-center justify-center rounded-full border shrink-0"
              style="width: 30px; height: 30px; border-color: var(--color-accent); border-width: 1.5px; color: var(--color-accent); font-family: var(--font-serif); font-size: 14px; font-style: italic;">{event.initial}</span>
        <span style="font-family: var(--font-serif); font-size: 20px; font-weight: 400;">
          {event.nameShort} <em style="color: var(--color-accent); font-style: italic;">{event.nameEmphasis}</em>
        </span>
      </div>
      <div class="text-[10px] tracking-[0.24em] opacity-55 mb-3.5" style="font-family: var(--font-mono);">
        ÉDITION {event.edition} · {event.year}
      </div>
      <p class="text-[13px] leading-[1.55] opacity-65 m-0 max-w-[340px]" style="text-wrap: pretty;">
        {event.dateFull} · {event.location}.
      </p>
    </div>

    <!-- Col 2 — Event -->
    <div>
      <div class="text-[10px] tracking-[0.26em] mb-4" style="font-family: var(--font-mono); color: var(--color-accent); opacity: 0.85;">
        ÉVÉNEMENT
      </div>
      <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
        {footer.eventLinks.map(l => (
          <li><a href={l.href} class="footer-link">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Col 3 — Contact -->
    <div>
      <div class="text-[10px] tracking-[0.26em] mb-4" style="font-family: var(--font-mono); color: var(--color-accent); opacity: 0.85;">
        CONTACT
      </div>
      <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
        {footer.contactLinks.map(l => (
          <li><a href={l.href} class="footer-link">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Col 4 — Partners -->
    <div>
      <div class="text-[10px] tracking-[0.26em] mb-4" style="font-family: var(--font-mono); color: var(--color-accent); opacity: 0.85;">
        AVEC
      </div>
      <div class="flex flex-wrap items-center gap-2.5">
        {footer.partners.map(p => (
          <div class="logo-tile partner-tile" style="padding: 6px; border-radius: 2px;">
            <img src={withBase(p.logo)} alt={p.name}
                 style="height: 42px; object-fit: contain; display: block;"
                 onerror="this.closest('.partner-tile')?.remove();" />
          </div>
        ))}
      </div>
      <div class="text-[10px] tracking-[0.16em] opacity-50 mt-3 leading-[1.6]" style="font-family: var(--font-mono);">
        {footer.partners.map((p, i) => (
          <>{p.name}{i < footer.partners.length - 1 && <br/>}</>
        ))}
      </div>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row lg:justify-between lg:items-center gap-2.5 lg:gap-5 text-[10px] tracking-[0.2em] opacity-45"
       style="font-family: var(--font-mono); padding-top: clamp(20px, 2.5vw, 24px); border-top: 1px solid rgba(232,227,211,0.08);">
    <div>{footer.legal}</div>
    <div class="flex gap-6">
      {footer.legalLinks.map(l => (
        <a href={l.href} class="no-underline" style="color: inherit;">{l.label}</a>
      ))}
    </div>
  </div>
</footer>

<style>
  .footer-link {
    color: var(--color-ink);
    text-decoration: none;
    font-size: 13px;
    opacity: 0.8;
    transition: color 0.2s ease, opacity 0.2s ease;
  }
  .footer-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }
</style>
