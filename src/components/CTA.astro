---
interface Props {
  data: {
    label: string;
    titleLine1: string;
    titleEmphasis: string;
    titleSuffix: string;
    button: string;
  };
  registrationUrl: string;
}
const { data, registrationUrl } = Astro.props;
---
<section id="inscription"
  class="text-center border-t border-[color:var(--color-line-soft)]"
  style="background: var(--color-bg-deep); padding: clamp(64px, 9vw, 96px) clamp(20px, 4vw, 80px) clamp(48px, 7vw, 72px);">

  <div class="mono-label mb-5" style="letter-spacing: 0.32em; margin-bottom: clamp(20px, 2.5vw, 28px);" set:html={data.label} />
  <h2
      style="font-family: var(--font-serif); font-weight: 400; line-height: 0.9; letter-spacing: -0.035em; font-size: clamp(56px, 9vw, 108px); margin: 0 0 clamp(28px, 4vw, 40px);">
    {data.titleLine1} <em style="color: var(--color-accent); font-style: italic;">{data.titleEmphasis}</em> {data.titleSuffix}
  </h2>
  <a href={registrationUrl} target="_blank" rel="noopener noreferrer"
     class="btn-gold w-full sm:w-auto"
     style="padding: clamp(16px, 1.8vw, 18px) clamp(28px, 3.5vw, 40px); font-size: 12px; letter-spacing: 0.22em;">{data.button}</a>
</section>
