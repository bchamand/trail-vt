---
// Génère TOUTES les balises de référencement d'une page, en statique :
// title, meta description, canonical, robots, Open Graph, Twitter Card, JSON-LD.
// Placé dans le <head> de Layout.astro → présent dès le 1er rendu (pas de JS).
import { stripHtml } from '../lib/seo';

interface Props {
  title: string;
  description: string; // peut contenir du HTML : nettoyé pour les balises
  image?: string; // chemin de l'image de partage (défaut : photo du hero)
  imageWidth?: number;
  imageHeight?: number;
  ogType?: string; // 'website' | 'article'
  siteName?: string;
  jsonLd?: object; // données structurées Schema.org
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/images/hero-poster.jpg',
  imageWidth = 1920,
  imageHeight = 1080,
  ogType = 'website',
  siteName = 'Trail des Tectosages',
  jsonLd,
  noindex = false,
} = Astro.props;

const site = Astro.site ?? new URL('https://www.traildestectosages.fr');
const canonical = new URL(Astro.url.pathname, site).href;
const imageUrl = new URL(image, site).href;
const desc = stripHtml(description);
const robots = noindex
  ? 'noindex, follow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
---
<title>{title}</title>
<meta name="description" content={desc} />
<meta name="robots" content={robots} />
<link rel="canonical" href={canonical} />

{/* Open Graph (Facebook, LinkedIn, WhatsApp…) */}
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="fr_FR" />
<meta property="og:title" content={title} />
<meta property="og:description" content={desc} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={title} />
<meta property="og:image:width" content={String(imageWidth)} />
<meta property="og:image:height" content={String(imageHeight)} />

{/* Twitter Card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={desc} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={title} />

{jsonLd && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
)}
