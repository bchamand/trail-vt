---
---
<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden hero-bg">
  <!-- Multi-layer overlay: darken top for readability, warm midtone, fade bottom to cream for seamless join -->
  <div class="absolute inset-0 bg-gradient-to-b from-moss-dark/75 via-charcoal/50 to-cream"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-moss-dark/30 via-transparent to-terracotta/20"></div>

  <!-- Grain texture -->
  <div class="absolute inset-0 grain-overlay"></div>

  <!-- Subtle decorative ring -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-cream/10"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[420px] h-[420px] rounded-full border border-cream/5"></div>
  </div>

  <div class="relative z-10 text-center px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto pt-20 pb-32 sm:pb-40">
    <!-- Petit label -->
    <p class="text-cream/80 uppercase tracking-[0.3em] text-xs sm:text-sm mb-6 font-sans font-medium">
      Vieille-Toulouse &bull; Samedi 3 octobre 2026
    </p>

    <!-- Titre principal -->
    <h1 class="font-serif text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold text-cream leading-[0.95] mb-6 drop-shadow-lg">
      Trail des<br/>
      <span class="text-tile">Tectosages</span>
    </h1>

    <!-- Baseline -->
    <p class="font-serif italic text-cream/90 text-lg sm:text-xl md:text-2xl mb-4 drop-shadow">
      Sur la trace des Volques Tectosages
    </p>

    <!-- Separator -->
    <div class="celtic-separator celtic-separator-light my-8">◆</div>

    <!-- Description courte -->
    <p class="text-cream/85 max-w-xl mx-auto text-sm sm:text-base mb-10 leading-relaxed drop-shadow">
      Vieille-Toulouse fut la capitale des Volques Tectosages il y a 2300 ans.
      Rel&egrave;verez-vous le D&eacute;fi de Copilos, dernier chef gaulois&nbsp;?
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 items-center justify-center">
      <a href="#epreuves" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-terracotta hover:bg-terracotta-dark text-cream px-8 py-4 rounded-full font-sans font-semibold text-sm sm:text-base transition-all duration-300 hover:scale-105 shadow-lg shadow-charcoal/40 hover:shadow-terracotta/40">
        D&eacute;couvrir les &eacute;preuves
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
      <a
        href="https://chrono-start.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-cream/10 hover:bg-cream/20 backdrop-blur text-cream border border-cream/40 hover:border-cream/70 px-8 py-4 rounded-full font-sans font-semibold text-sm sm:text-base transition-all duration-300 hover:scale-105"
      >
        S'inscrire
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-cream/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
