---
import type { EventView } from '../lib/event';
import { withBase } from '../lib/url';
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  event: EventView;
}
const { event } = Astro.props;

// Vidéos du hero : tous les fichiers public/video/heroN.mp4, triés par numéro,
// joués les uns à la suite des autres (en boucle). Ajouter / retirer une vidéo
// = déposer / supprimer un fichier « heroN.mp4 » dans public/video/, rien d'autre.
let heroVideos: string[] = [];
try {
  heroVideos = fs.readdirSync(path.join(process.cwd(), 'public', 'video'))
    .filter(f => /^hero\d+\.mp4$/i.test(f))
    .sort((a, b) => parseInt(a.match(/\d+/)![0], 10) - parseInt(b.match(/\d+/)![0], 10))
    .map(f => withBase(`/video/${f}`));
} catch { /* dossier absent → le poster suffit */ }
// Repli : aucune heroN.mp4 → on retombe sur event.heroMedia (vidéo unique).
if (heroVideos.length === 0 && /\.(mp4|webm|mov)$/i.test(event.heroMedia)) {
  heroVideos = [withBase(event.heroMedia)];
}
const hasVideo = heroVideos.length > 0;
const posterUrl = withBase('/images/hero-poster.jpg');
---
<section id="top" class="relative overflow-hidden" style="min-height: 100vh; min-height: 100svh;">
  <!-- Poster (frame statique) en fond. Au-dessus, DEUX calques vidéo (a sous b)
       qui se fondent l'un dans l'autre : pendant qu'un clip joue, le suivant est
       préchargé dans le calque caché, puis on bascule l'opacité → la vidéo
       s'enchaîne sans jamais laisser réapparaître le poster entre deux clips.
       Si l'autoplay est bloqué, les vidéos sont retirées et le poster reste. -->
  <img id="hero-poster" src={posterUrl} alt="" class="hero-layer" />
  {hasVideo && (
    <>
      <video
        id="hero-a"
        class="hero-layer hero-vid"
        data-playlist={JSON.stringify(heroVideos)}
        src={heroVideos[0]}
        autoplay
        muted
        playsinline
        preload="auto"
      />
      <video
        id="hero-b"
        class="hero-layer hero-vid"
        muted
        playsinline
        preload="auto"
        style="opacity: 0;"
      />
    </>
  )}

  <div class="absolute inset-0 pointer-events-none"
       style="background: linear-gradient(to bottom, rgba(15,20,18,0.55) 0%, transparent 30%, transparent 55%, rgba(15,20,18,0.95) 100%);"></div>

  <div class="grain"></div>

  <div class="absolute inset-0 flex flex-col justify-end px-5 pb-10 sm:px-10 sm:pb-16 lg:px-20 lg:pb-16">
    <!-- Edition line: short horizontal bar + label -->
    <div class="flex items-center gap-3 sm:gap-3.5" style="margin-bottom: clamp(14px, 2vw, 22px);">
      <span class="block" style="width: clamp(24px, 3vw, 36px); height: 1px; background: var(--color-accent);"></span>
      <span class="text-[10px] sm:text-[11px] tracking-[0.28em]"
            style="font-family: var(--font-mono); font-weight: 600; color: var(--color-accent);">
        ÉDITION {event.edition}
      </span>
    </div>

    <!-- Title -->
    <h1 style="font-family: var(--font-serif); font-weight: 400; line-height: 0.86; letter-spacing: -0.038em; margin: 0; font-size: clamp(52px, 12vw, 156px);">
      {event.nameShort}<br/><em style="font-style: italic; color: var(--color-accent);">{event.nameEmphasis}</em>
    </h1>

    <!-- Location + date under the title -->
    <div class="flex flex-col gap-2 sm:gap-2.5" style="margin-top: clamp(14px, 2vw, 22px);">
      <div class="flex items-center gap-2.5">
        <svg width="13" height="15" viewBox="0 0 24 30" fill="none" stroke="var(--color-accent)" stroke-width="2" style="flex-shrink: 0;">
          <path d="M12 2 C 6 2 2 7 2 12 C 2 20 12 28 12 28 C 12 28 22 20 22 12 C 22 7 18 2 12 2 Z"/>
          <circle cx="12" cy="12" r="3.2"/>
        </svg>
        <span class="text-[10px] sm:text-[11px] tracking-[0.3em]"
              style="font-family: var(--font-mono); color: rgba(232,227,211,0.6);">
          {event.locationShort}
        </span>
      </div>
      <div class="flex items-center gap-2.5">
        <svg width="13" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.8" style="flex-shrink: 0;">
          <rect x="3" y="5" width="18" height="16" rx="1"/>
          <path d="M3 10h18M8 3v4M16 3v4"/>
        </svg>
        <span class="text-[10px] sm:text-[11px] tracking-[0.3em] uppercase"
              style="font-family: var(--font-mono); color: rgba(232,227,211,0.6);">
          {event.dateFull}
        </span>
      </div>
    </div>

    <!-- Tagline (secondary) — short thick accent bar + continuation rule -->
    <div class="hero-tagline relative" style="margin-top: clamp(18px, 2.5vw, 28px); padding-top: clamp(20px, 2.5vw, 26px); margin-bottom: clamp(8px, 1vw, 12px);">
      <div class="hero-tagline-bar"></div>
      <div class="hero-tagline-rule"></div>
      <p style="font-family: var(--font-serif); font-style: italic; font-weight: 400; line-height: 1.2; margin: 0; opacity: 0.95; text-wrap: balance; max-width: 820px; font-size: clamp(22px, 3.2vw, 36px); text-shadow: 0 2px 20px rgba(0,0,0,0.5);">
        {event.tagline}
      </p>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-5"
         style="margin-top: clamp(20px, 3vw, 32px);">
      <p class="max-w-[620px] text-[13px] sm:text-[15px] opacity-80 leading-[1.5] m-0" style="text-wrap: pretty;" set:html={event.description} />
      <div class="sm:hidden w-full">
        <a href={event.urls.registration} target="_blank" rel="noopener noreferrer"
           class="btn-gold w-full" style="padding: 16px 28px;">{event.heroCtaLabel}</a>
      </div>
      <div class="hidden sm:flex items-center gap-3">
        <span class="text-[11px] tracking-[0.2em] opacity-70" style="font-family: var(--font-mono);">SCROLL</span>
        <div style="width: 1px; height: 32px; background: rgba(232,227,211,0.4);"></div>
      </div>
    </div>
  </div>
</section>

<style>
  /* calques média du hero (poster + 2 vidéos) : même cadrage et traitement */
  .hero-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 110%;
    object-fit: cover;
    object-position: center 40%;
    filter: brightness(0.7) contrast(1.1) saturate(0.85);
    transform: translateY(0) scale(1.05);
    pointer-events: none;
  }
  /* fondu d'opacité entre les deux calques vidéo (voir le <script>) */
  .hero-vid { transition: opacity 0.6s ease; }

  .hero-tagline-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 56px;
    height: 3px;
    background: var(--color-accent);
  }
  .hero-tagline-rule {
    position: absolute;
    top: 1px;
    left: 56px;
    right: 0;
    height: 1px;
    background: rgba(232, 227, 211, 0.28);
  }
  @media (min-width: 720px) {
    .hero-tagline-bar { width: 88px; }
    .hero-tagline-rule { left: 88px; }
  }
</style>

<script>
  const a = document.getElementById('hero-a') as HTMLVideoElement | null;
  const b = document.getElementById('hero-b') as HTMLVideoElement | null;
  const poster = document.getElementById('hero-poster') as HTMLImageElement | null;
  const layers = [a, b, poster].filter(Boolean) as HTMLElement[];

  // Parallaxe sur les calques présents.
  let ticking = false;
  function update() {
    const y = window.scrollY;
    const t = `translateY(${y * 0.3}px) scale(1.05)`;
    layers.forEach(el => { el.style.transform = t; });
    ticking = false;
  }
  window.addEventListener('scroll', () => {
    if (!ticking) { requestAnimationFrame(update); ticking = true; }
  }, { passive: true });

  if (a && b) {
    let playlist: string[] = [];
    try { playlist = JSON.parse(a.dataset.playlist || '[]'); } catch {}

    if (playlist.length > 1) {
      // Deux calques (b au-dessus de a). Le clip suivant est préchargé dans le
      // calque caché ; à la fin du clip courant on le lance et on bascule
      // l'opacité de b (fondu) → enchaînement sans réapparition du poster.
      let showing = a, hidden = b, idx = 0;
      b.src = playlist[1];
      b.load();
      const onEnded = (e: Event) => {
        if (e.target !== showing) return;
        idx = (idx + 1) % playlist.length;
        const incoming = hidden, outgoing = showing;
        incoming.currentTime = 0;
        incoming.play().catch(() => {});
        b.style.opacity = incoming === b ? '1' : '0';
        showing = incoming;
        hidden = outgoing;
        // une fois le fondu fini, précharge le clip d'après dans le calque caché
        const followIdx = (idx + 1) % playlist.length;
        window.setTimeout(() => { outgoing.src = playlist[followIdx]; outgoing.load(); }, 700);
      };
      a.addEventListener('ended', onEnded);
      b.addEventListener('ended', onEnded);
    } else {
      a.loop = true; // une seule vidéo → boucle native
    }

    // Autoplay bloqué (mode éco iOS/macOS Safari) → on retire les deux vidéos,
    // le poster reste (aucun bouton « play » natif ne peut apparaître).
    const giveUp = () => { a.remove(); b.remove(); };
    a.play?.().catch(giveUp);
    setTimeout(() => { if (a.paused) giveUp(); }, 1200);
  }
</script>
