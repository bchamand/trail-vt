---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/url';

interface Props {
  event: CollectionEntry<'event'>['data'];
}
const { event } = Astro.props;
const heroBg = withBase(event.heroImage);
---
<section id="top" class="relative overflow-hidden" style="min-height: 88vh;">
  <img
    id="hero-img"
    src={heroBg}
    alt=""
    class="absolute inset-0 w-full object-cover pointer-events-none"
    style="height: 110%; object-position: center 40%; filter: brightness(0.7) contrast(1.1) saturate(0.85); transform: translateY(0) scale(1.05); will-change: transform;"
  />

  <div class="absolute inset-0 pointer-events-none"
       style="background: linear-gradient(to bottom, rgba(15,20,18,0.55) 0%, transparent 30%, transparent 55%, rgba(15,20,18,0.95) 100%);"></div>

  <div class="grain"></div>

  <div class="absolute inset-0 flex flex-col justify-end px-5 pb-10 sm:px-10 sm:pb-16 lg:px-20 lg:pb-16">
    <div class="inline-flex self-start items-center gap-2.5"
         style="padding: 7px 12px; border: 1px solid var(--color-accent); color: var(--color-accent); margin-bottom: 20px; background: rgba(15,20,18,0.35); backdrop-filter: blur(6px);">
      <span style="width: 6px; height: 6px; background: var(--color-accent); border-radius: 50%; display: inline-block;"></span>
      <span class="text-[10px] sm:text-[11px] tracking-[0.28em]" style="font-family: var(--font-mono); font-weight: 600;">ÉDITION {event.edition} · {event.year}</span>
      <span style="width: 1px; height: 12px; background: rgba(212,165,116,0.5);"></span>
      <span class="text-[10px] sm:text-[11px] tracking-[0.2em] opacity-85" style="font-family: var(--font-mono);">
        <span class="sm:hidden">{event.dateShortMobile}</span>
        <span class="hidden sm:inline">{event.dateShort}</span>
      </span>
    </div>

    <div style="margin-bottom: clamp(18px, 3vw, 28px);">
      <div class="text-[10px] sm:text-[11px] tracking-[0.3em]"
           style="font-family: var(--font-mono); color: rgba(232,227,211,0.6); margin-bottom: clamp(10px, 1.5vw, 14px);">
        {event.locationShort}
      </div>
      <h1 style="font-family: var(--font-serif); font-weight: 400; line-height: 0.86; letter-spacing: -0.038em; margin: 0; font-size: clamp(52px, 12vw, 156px);">
        {event.nameShort}<br/><em style="font-style: italic; color: var(--color-accent);">{event.nameEmphasis}.</em>
      </h1>
    </div>

    <div style="padding-top: clamp(18px, 2.5vw, 24px); border-top: 1px solid rgba(232,227,211,0.18); margin-bottom: clamp(8px, 1vw, 12px);">
      <p style="font-family: var(--font-serif); font-style: italic; font-weight: 400; line-height: 1.2; margin: 0; opacity: 0.95; text-wrap: balance; max-width: 820px; font-size: clamp(22px, 3.2vw, 36px);">
        {event.tagline}
      </p>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-5"
         style="margin-top: clamp(20px, 3vw, 32px);">
      <p class="max-w-[440px] text-[13px] sm:text-[15px] opacity-80 leading-[1.5] m-0" style="text-wrap: pretty;">
        {event.description}
      </p>
      <div class="sm:hidden w-full">
        <a href={event.urls.registration} target="_blank" rel="noopener noreferrer"
           class="btn-gold w-full" style="padding: 16px 28px;">{event.heroCtaLabel}</a>
      </div>
      <div class="hidden sm:flex items-center gap-3">
        <span class="text-[11px] tracking-[0.2em] opacity-70" style="font-family: var(--font-mono);">SCROLL</span>
        <div style="width: 1px; height: 32px; background: rgba(232,227,211,0.4);"></div>
      </div>
    </div>
  </div>
</section>

<script>
  const img = document.getElementById('hero-img') as HTMLImageElement;
  let ticking = false;
  function update() {
    const y = window.scrollY;
    img.style.transform = `translateY(${y * 0.3}px) scale(1.05)`;
    ticking = false;
  }
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }, { passive: true });
</script>
