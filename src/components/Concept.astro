---
import { races } from '../data/races';
---
<section id="concept" class="relative py-20 sm:py-28 bg-charcoal grain-overlay">
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-gold uppercase tracking-[0.25em] text-xs font-medium mb-4">Un format inédit</p>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-cream mb-6">
        4 épreuves, 1 aventure
      </h2>
      <p class="text-cream/60 max-w-2xl mx-auto text-sm sm:text-base leading-relaxed">
        Le Trail des Tectosages réinvente la course nature avec un format unique :
        du trail classique à l'épreuve par élimination, chaque coureur trouvera son défi.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      {races.map((race, i) => (
        <a href="#epreuves" class="concept-card group block bg-charcoal border border-cream/10 rounded-xl p-6 hover:border-gold/30 transition-all duration-300 hover:-translate-y-1" data-concept-race={i}>
          <div class="text-3xl mb-4">{race.icon}</div>
          <p class="text-gold/80 text-xs uppercase tracking-wider mb-1 font-medium">{race.title}</p>
          <h3 class="font-serif text-xl font-bold text-cream mb-3 group-hover:text-gold transition-colors">
            <span class="concept-distance" data-concept-dist={i}>—</span> · {race.type}
          </h3>
          <p class="text-cream/50 text-sm leading-relaxed">{race.desc}</p>
        </a>
      ))}
    </div>

    <div class="celtic-separator mt-20"></div>

    <!-- Highlight: épreuve élimination -->
    <div class="max-w-3xl mx-auto text-center mt-8">
      <h3 class="font-serif text-2xl sm:text-3xl font-bold text-gold mb-6">
        L'Épreuve des Quatre Torques
      </h3>
      <p class="text-cream/70 text-sm sm:text-base leading-relaxed mb-4">
        Une course par élimination en 4 boucles.
        Chaque boucle doit être bouclée dans un temps imparti.
      </p>
      <div class="flex flex-wrap justify-center gap-3 mt-8">
        <div class="bg-forest/30 border border-gold/20 rounded-lg px-4 py-3 text-center min-w-[140px]">
          <p class="text-gold font-serif text-lg font-bold">Boucle 1</p>
          <p class="text-cream/60 text-xs mt-1">max 1h</p>
        </div>
        <div class="bg-forest/30 border border-gold/20 rounded-lg px-4 py-3 text-center min-w-[140px]">
          <p class="text-gold font-serif text-lg font-bold">Boucle 2</p>
          <p class="text-cream/60 text-xs mt-1">Départ à H+1h</p>
        </div>
        <div class="bg-forest/30 border border-gold/20 rounded-lg px-4 py-3 text-center min-w-[140px]">
          <p class="text-gold font-serif text-lg font-bold">Boucle 3</p>
          <p class="text-cream/60 text-xs mt-1">Départ à H+2h</p>
        </div>
        <div class="bg-forest/30 border border-gold/20 rounded-lg px-4 py-3 text-center min-w-[140px]">
          <p class="text-gold font-serif text-lg font-bold">Boucle 4</p>
          <p class="text-cream/60 text-xs mt-1">Départ à H+3h</p>
        </div>
      </div>
    </div>
  </div>
</section>
