---
---
<section id="infos" class="relative py-20 sm:py-28 bg-cream text-charcoal">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-terracotta uppercase tracking-[0.25em] text-xs font-medium mb-4">Informations</p>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-charcoal">
        Infos pratiques
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      <!-- Date & Lieu -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">📍</div>
        <h3 class="font-serif text-xl font-bold mb-3">Date & Lieu</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          <strong>Date :</strong> À confirmer<br/>
          <strong>Lieu :</strong> Vieille-Toulouse (31)<br/>
          <strong>Départ :</strong> Place de la Mairie
        </p>
      </div>

      <!-- Programme -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">🕐</div>
        <h3 class="font-serif text-xl font-bold mb-3">Programme</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          <strong>7h00 :</strong> Ouverture du village<br/>
          <strong>8h00 :</strong> Départ 32 km Élimination<br/>
          <strong>9h00 :</strong> Départ 12 km<br/>
          <strong>9h30 :</strong> Départ 6 km marche<br/>
          <strong>10h00 :</strong> Course enfants
        </p>
      </div>

      <!-- Accès -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">🚗</div>
        <h3 class="font-serif text-xl font-bold mb-3">Accès & Parking</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          Parking gratuit à proximité du départ.<br/>
          Accès en bus depuis Toulouse (ligne XX).<br/>
          Covoiturage encouragé !
        </p>
      </div>

      <!-- Ravitaillement -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">🥤</div>
        <h3 class="font-serif text-xl font-bold mb-3">Ravitaillement</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          Ravitaillements sur le parcours avec produits locaux du Lauragais.
          Point d'eau et fruits secs à chaque passage.
        </p>
      </div>

      <!-- Récompenses -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">🏅</div>
        <h3 class="font-serif text-xl font-bold mb-3">Récompenses</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          Médaille finisher pour tous les participants.
          Récompenses spéciales pour l'Épreuve des Quatre Torques.
        </p>
      </div>

      <!-- Contact -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">📧</div>
        <h3 class="font-serif text-xl font-bold mb-3">Contact</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          <strong>Email :</strong> contact@trail-tectosages.fr<br/>
          <strong>Facebook :</strong> @TrailDesTectosages<br/>
          <strong>Instagram :</strong> @trail_tectosages
        </p>
      </div>
    </div>
  </div>
</section>
