---
---
<section id="infos" class="relative py-20 sm:py-28 bg-stone grain-overlay">
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-terracotta uppercase tracking-[0.25em] text-xs font-medium mb-4">Informations</p>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-charcoal">
        Infos pratiques
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      <!-- Date & Lieu -->
      <div class="group bg-cream border border-charcoal/10 rounded-xl p-6 sm:p-8 hover:border-terracotta/40 hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="w-12 h-12 rounded-full bg-terracotta/10 flex items-center justify-center text-2xl mb-4 group-hover:bg-terracotta/20 transition-colors">📍</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-charcoal">Date & Lieu</h3>
        <p class="text-clay text-sm leading-relaxed">
          <strong class="text-charcoal">Samedi 3 octobre 2026</strong><br/>
          Vieille-Toulouse (31)<br/>
          <span class="text-clay/70 text-xs">Coucher du soleil à 19h32</span>
        </p>
      </div>

      <!-- Programme -->
      <div class="group bg-cream border border-charcoal/10 rounded-xl p-6 sm:p-8 hover:border-moss/40 hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="w-12 h-12 rounded-full bg-moss/10 flex items-center justify-center text-2xl mb-4 group-hover:bg-moss/20 transition-colors">🕐</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-charcoal">Départs</h3>
        <p class="text-clay text-sm leading-relaxed">
          <strong class="text-charcoal">15h45</strong> — Le Défi de Copilos<br/>
          <strong class="text-charcoal">16h15</strong> — La Boucle de l'Oppidum<br/>
          <strong class="text-charcoal">16h30</strong> — L'Oppi-dog<br/>
          <strong class="text-charcoal">16h30</strong> — La Randonnée des Sages<br/>
          <strong class="text-charcoal">18h00</strong> — La Tectokids
        </p>
      </div>

      <!-- Accès -->
      <div class="group bg-cream border border-charcoal/10 rounded-xl p-6 sm:p-8 hover:border-moss/40 hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="w-12 h-12 rounded-full bg-moss/10 flex items-center justify-center text-2xl mb-4 group-hover:bg-moss/20 transition-colors">🚗</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-charcoal">Accès & Parking</h3>
        <p class="text-clay text-sm leading-relaxed">
          Parking gratuit à proximité du départ.<br/>
          Accès en bus depuis Toulouse.<br/>
          Covoiturage encouragé&nbsp;!
        </p>
      </div>

      <!-- Ravitaillement -->
      <div class="group bg-cream border border-charcoal/10 rounded-xl p-6 sm:p-8 hover:border-moss/40 hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="w-12 h-12 rounded-full bg-moss/10 flex items-center justify-center text-2xl mb-4 group-hover:bg-moss/20 transition-colors">🥤</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-charcoal">Ravitaillement</h3>
        <p class="text-clay text-sm leading-relaxed">
          Ravitaillements sur le parcours avec produits locaux du Lauragais.
          Point d'eau et fruits secs à chaque passage.
        </p>
      </div>

      <!-- Récompenses -->
      <div class="group bg-cream border border-charcoal/10 rounded-xl p-6 sm:p-8 hover:border-terracotta/40 hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="w-12 h-12 rounded-full bg-terracotta/10 flex items-center justify-center text-2xl mb-4 group-hover:bg-terracotta/20 transition-colors">🏅</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-charcoal">Récompenses</h3>
        <p class="text-clay text-sm leading-relaxed">
          Le <strong class="text-charcoal">Breuvage des Conquérants</strong> pour tous les finishers.<br/>
          Médaille en terre cuite.<br/>
          Statut d'« <span class="text-terracotta font-medium">Héritier de Copilos</span> » pour les élus.
        </p>
      </div>

      <!-- Organisateurs -->
      <div class="group bg-cream border border-charcoal/10 rounded-xl p-6 sm:p-8 hover:border-terracotta/40 hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="w-12 h-12 rounded-full bg-terracotta/10 flex items-center justify-center text-2xl mb-4 group-hover:bg-terracotta/20 transition-colors">👥</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-charcoal">Organisation</h3>
        <p class="text-clay text-sm leading-relaxed">
          Le trail est organisé par l'<strong class="text-charcoal">Association Trail des Tectosages</strong>.<br/>
          Le banquet est organisé par le <strong class="text-charcoal">Comité des Fêtes</strong> de Vieille-Toulouse.
        </p>
      </div>
    </div>
  </div>
</section>
