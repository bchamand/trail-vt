---
---
<section id="infos" class="relative py-20 sm:py-28 bg-cream text-charcoal">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-terracotta uppercase tracking-[0.25em] text-xs font-medium mb-4">Informations</p>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-charcoal">
        Infos pratiques
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      <!-- Date & Lieu -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">📍</div>
        <h3 class="font-serif text-xl font-bold mb-3">Date & Lieu</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          <strong>Samedi 3 octobre 2026</strong><br/>
          Vieille-Toulouse (31)<br/>
          <span class="text-charcoal/50 text-xs">Coucher du soleil à 19h32</span>
        </p>
      </div>

      <!-- Programme -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">🕐</div>
        <h3 class="font-serif text-xl font-bold mb-3">Départs</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          <strong>15h45</strong> — Le Défi de Copilos<br/>
          <strong>16h15</strong> — La Boucle de l'Oppidum<br/>
          <strong>16h30</strong> — L'Oppi-dog<br/>
          <strong>16h30</strong> — La Randonnée des Sages<br/>
          <strong>18h00</strong> — La Tectokids
        </p>
      </div>

      <!-- Accès -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">🚗</div>
        <h3 class="font-serif text-xl font-bold mb-3">Accès & Parking</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          Parking gratuit à proximité du départ.<br/>
          Accès en bus depuis Toulouse.<br/>
          Covoiturage encouragé&nbsp;!
        </p>
      </div>

      <!-- Ravitaillement -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">🥤</div>
        <h3 class="font-serif text-xl font-bold mb-3">Ravitaillement</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          Ravitaillements sur le parcours avec produits locaux du Lauragais.
          Point d'eau et fruits secs à chaque passage.
        </p>
      </div>

      <!-- Récompenses -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">🏅</div>
        <h3 class="font-serif text-xl font-bold mb-3">Récompenses</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          Le <strong>Breuvage des Conquérants</strong> pour tous les finishers.<br/>
          Médaille en terre cuite.<br/>
          Statut d'« Héritier de Copilos » pour les élus.
        </p>
      </div>

      <!-- Organisateurs -->
      <div class="bg-white/60 rounded-xl p-6 sm:p-8 border border-charcoal/5">
        <div class="text-terracotta text-2xl mb-4">👥</div>
        <h3 class="font-serif text-xl font-bold mb-3">Organisation</h3>
        <p class="text-charcoal/70 text-sm leading-relaxed">
          Le trail est organisé par l'<strong>Association Trail des Tectosages</strong>.<br/>
          Le banquet est organisé par le <strong>Comité des Fêtes</strong> de Vieille-Toulouse.
        </p>
      </div>
    </div>
  </div>
</section>
