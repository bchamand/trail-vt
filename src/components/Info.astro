---
---
<section id="infos" class="relative py-20 sm:py-28 bg-charcoal-light grain-overlay">
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-gold uppercase tracking-[0.25em] text-xs font-medium mb-4">Informations</p>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-bold text-cream">
        Infos pratiques
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      <!-- Date & Lieu -->
      <div class="bg-charcoal border border-cream/10 rounded-xl p-6 sm:p-8 hover:border-gold/30 transition-colors">
        <div class="text-terracotta text-2xl mb-4">📍</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-cream">Date & Lieu</h3>
        <p class="text-cream/60 text-sm leading-relaxed">
          <strong class="text-cream">Samedi 3 octobre 2026</strong><br/>
          Vieille-Toulouse (31)<br/>
          <span class="text-cream/40 text-xs">Coucher du soleil à 19h32</span>
        </p>
      </div>

      <!-- Programme -->
      <div class="bg-charcoal border border-cream/10 rounded-xl p-6 sm:p-8 hover:border-gold/30 transition-colors">
        <div class="text-terracotta text-2xl mb-4">🕐</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-cream">Départs</h3>
        <p class="text-cream/60 text-sm leading-relaxed">
          <strong class="text-cream">15h45</strong> — Le Défi de Copilos<br/>
          <strong class="text-cream">16h15</strong> — La Boucle de l'Oppidum<br/>
          <strong class="text-cream">16h30</strong> — L'Oppi-dog<br/>
          <strong class="text-cream">16h30</strong> — La Randonnée des Sages<br/>
          <strong class="text-cream">18h00</strong> — La Tectokids
        </p>
      </div>

      <!-- Accès -->
      <div class="bg-charcoal border border-cream/10 rounded-xl p-6 sm:p-8 hover:border-gold/30 transition-colors">
        <div class="text-terracotta text-2xl mb-4">🚗</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-cream">Accès & Parking</h3>
        <p class="text-cream/60 text-sm leading-relaxed">
          Parking gratuit à proximité du départ.<br/>
          Accès en bus depuis Toulouse.<br/>
          Covoiturage encouragé&nbsp;!
        </p>
      </div>

      <!-- Ravitaillement -->
      <div class="bg-charcoal border border-cream/10 rounded-xl p-6 sm:p-8 hover:border-gold/30 transition-colors">
        <div class="text-terracotta text-2xl mb-4">🥤</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-cream">Ravitaillement</h3>
        <p class="text-cream/60 text-sm leading-relaxed">
          Ravitaillements sur le parcours avec produits locaux du Lauragais.
          Point d'eau et fruits secs à chaque passage.
        </p>
      </div>

      <!-- Récompenses -->
      <div class="bg-charcoal border border-cream/10 rounded-xl p-6 sm:p-8 hover:border-gold/30 transition-colors">
        <div class="text-terracotta text-2xl mb-4">🏅</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-cream">Récompenses</h3>
        <p class="text-cream/60 text-sm leading-relaxed">
          Le <strong class="text-cream">Breuvage des Conquérants</strong> pour tous les finishers.<br/>
          Médaille en terre cuite.<br/>
          Statut d'« Héritier de Copilos » pour les élus.
        </p>
      </div>

      <!-- Organisateurs -->
      <div class="bg-charcoal border border-cream/10 rounded-xl p-6 sm:p-8 hover:border-gold/30 transition-colors">
        <div class="text-terracotta text-2xl mb-4">👥</div>
        <h3 class="font-serif text-xl font-bold mb-3 text-cream">Organisation</h3>
        <p class="text-cream/60 text-sm leading-relaxed">
          Le trail est organisé par l'<strong class="text-cream">Association Trail des Tectosages</strong>.<br/>
          Le banquet est organisé par le <strong class="text-cream">Comité des Fêtes</strong> de Vieille-Toulouse.
        </p>
      </div>
    </div>
  </div>
</section>
