---
// Export PDF A4 de l'affiche 1.
// On récupère la page /affiche1 (source unique), on y injecte jsPDF + snapdom +
// une barre d'export, puis on la rend dans CE document → les polices sont
// chargées là où snapdom capture, donc embarquées fidèlement dans le PDF.
import { withBase } from '../../lib/url';
const afficheUrl = withBase('/affiche1');
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Export PDF · Affiche · Trail des Tectosages</title>
</head>
<body style="margin:0;background:#0a0e0c;color:#e8e3d3;font-family:ui-monospace,monospace;">
<p id="boot" style="padding:28px;letter-spacing:.12em;font-size:13px;">Chargement de l’affiche…</p>
<script is:inline define:vars={{ afficheUrl }}>
(async function () {
  try {
    var html = await (await fetch(afficheUrl, { cache: 'no-cache' })).text();

    // libs dans le <head>
    var head =
      '<script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.2/dist/jspdf.umd.min.js"><\/script>' +
      '<script src="https://cdn.jsdelivr.net/npm/@zumer/snapdom@2.12.8/dist/snapdom.js"><\/script>';
    html = html.replace('</head>', head + '</head>');

    // barre d'export + logique, juste avant </body> (donc après les scripts de l'affiche)
    var ui =
      '<div id="xbar" style="position:fixed;left:0;right:0;top:0;z-index:99999;display:flex;gap:10px;align-items:center;' +
      'padding:10px 14px;background:rgba(10,14,12,.92);border-bottom:1px solid rgba(232,227,211,.16);' +
      'font-family:ui-monospace,monospace;-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);">' +
      '<button id="xdl" disabled style="font:inherit;font-size:12px;letter-spacing:.08em;color:#0f1412;background:#d4a574;' +
      'border:none;border-radius:7px;padding:9px 16px;cursor:pointer;">Télécharger le PDF</button>' +
      '<button id="xagain" style="font:inherit;font-size:12px;letter-spacing:.08em;color:#e8e3d3;background:transparent;' +
      'border:1px solid rgba(232,227,211,.16);border-radius:7px;padding:9px 16px;cursor:pointer;">Relancer</button>' +
      '<span id="xstatus" style="font-size:11px;letter-spacing:.06em;color:#8a8576;">…</span>' +
      '</div>' +
      '<script>' + exportLogic() + '<\/script>';
    html = html.replace('</body>', ui + '</body>');

    document.open(); document.write(html); document.close();
  } catch (e) {
    document.getElementById('boot').textContent = 'Échec du chargement : ' + (e && e.message || e);
  }

  // logique d'export, sérialisée telle quelle dans le document réécrit
  function exportLogic() { return '(' + (function () {
    var W = 1024, H = 1448;   // canevas natif (ratio A4)
    var SCALE = 3;            // 1024×3 ≈ 372 DPI sur A4
    var JPEG_Q = 0.95;
    var BAKE_TIMEOUT = 12000; // attente max de la « cuisson » de la carte de relief

    var statusEl = document.getElementById('xstatus');
    var dlBtn = document.getElementById('xdl');
    var againBtn = document.getElementById('xagain');
    var lastCanvas = null;
    function set(m) { statusEl.textContent = m; }
    function wait(ms) { return new Promise(function (r) { setTimeout(r, ms); }); }

    // La carte de relief est rendue en WebGL (non capturable par snapdom). L'affiche
    // en « cuit » une copie PNG (#elevbake), mais cette carte se construit
    // PROGRESSIVEMENT (tuiles d'altitude + calcul des courbes) : cuire trop tôt
    // donne des courbes grossières/fausses. On attend donc que la carte soit
    // STABILISÉE (idle = toutes tuiles chargées), on force une cuisson fraîche et
    // fidèle, et seulement ensuite on bascule sur le PNG pour la capture.
    async function waitMapSettled() {
      var elapsed = 0;
      while (!window.__emap && elapsed < BAKE_TIMEOUT) { await wait(200); elapsed += 200; }
      var m = window.__emap;
      if (!m) return false;
      var idleSeen = false;
      m.on('idle', function () { idleSeen = true; });
      while (elapsed < BAKE_TIMEOUT &&
             !(idleSeen && m.areTilesLoaded && m.areTilesLoaded())) {
        await wait(250); elapsed += 250;
      }
      await wait(600); // marge pour le dernier rendu des courbes
      return true;
    }
    // bascule live → PNG cuit, appliquée seulement à la capture
    var swapStyle = document.createElement('style');
    swapStyle.textContent = '#elevmap{display:none!important;}#elevbake{display:block!important;}';

    async function capture() {
      dlBtn.disabled = true; againBtn.disabled = true;
      var poster = document.getElementById('poster');
      try {
        set('Préparation (polices)…');
        if (document.fonts && document.fonts.ready) { try { await document.fonts.ready; } catch (e) {} }

        set('Rendu de la carte de relief…');
        var settled = await waitMapSettled();
        if (settled && typeof window.__bakeElev === 'function') {
          window.__bakeElev(); await wait(300);
          window.__bakeElev(); await wait(450);   // double cuisson → dernier état stabilisé
        } else if (!settled) {
          set('Relief indisponible (hors-ligne ?) — capture sans relief…');
        }
        if (!swapStyle.parentNode) document.head.appendChild(swapStyle);
        await wait(150);

        var prev = poster.style.transform;
        poster.style.transform = 'none';
        set('Capture du rendu (' + SCALE + '×)…');
        lastCanvas = await window.snapdom.toCanvas(poster, {
          scale: SCALE, dpr: 1, embedFonts: true,
          backgroundColor: '#0f1412', width: W, height: H
        });
        poster.style.transform = prev;
        window.dispatchEvent(new Event('resize'));

        set('Prêt — ' + lastCanvas.width + '×' + lastCanvas.height + ' px. Cliquez « Télécharger le PDF ».');
        dlBtn.disabled = false; againBtn.disabled = false;
      } catch (err) {
        console.error(err); set('Échec : ' + (err && err.message || err)); againBtn.disabled = false;
      }
    }

    function download() {
      if (!lastCanvas) return;
      set('Génération du PDF…');
      try {
        var data = lastCanvas.toDataURL('image/jpeg', JPEG_Q);
        var jsPDF = window.jspdf.jsPDF;
        var pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4', compress: true });
        pdf.addImage(data, 'JPEG', 0, 0, 210, 297, undefined, 'FAST'); // plein cadre A4
        pdf.save('Affiche 1 - Trail des Tectosages.pdf');
        set('PDF téléchargé.');
      } catch (err) { console.error(err); set('Échec PDF : ' + (err && err.message || err)); }
    }

    dlBtn.addEventListener('click', download);
    againBtn.addEventListener('click', capture);
    if (document.readyState === 'complete') capture();
    else window.addEventListener('load', capture);
  }).toString() + ')();'; }
})();
</script>
</body>
</html>
