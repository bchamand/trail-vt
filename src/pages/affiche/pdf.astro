---
// Export PDF A4 de l'affiche.
// On récupère /affiche (source unique), on y injecte jsPDF + snapdom + un VOILE de
// chargement opaque, on la rend dans CE document (polices embarquées fidèlement), on
// capture l'affiche DERRIÈRE le voile (elle n'est jamais montrée), puis on remplace tout
// par le PDF affiché dans la visionneuse du navigateur. Aucun clic, aucune étape visible.
import { withBase } from '../../lib/url';
const afficheUrl = withBase('/affiche');
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Affiche · Trail des Tectosages (PDF)</title>
<style>
  html,body{margin:0;height:100%;background:#0a0e0c;}
  #boot{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;
    color:#8a8576;font:13px/1.5 ui-monospace,monospace;letter-spacing:.18em;
    animation:xpulse 1.6s ease-in-out infinite;}
  @keyframes xpulse{0%,100%{opacity:.4}50%{opacity:1}}
</style>
</head>
<body>
<div id="boot">Génération du PDF…</div>
<script is:inline define:vars={{ afficheUrl }}>
(async function () {
  try {
    var html = await (await fetch(afficheUrl, { cache: 'no-cache' })).text();
    // libs + keyframe du voile dans le <head>
    var head =
      '<script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.2/dist/jspdf.umd.min.js"><\/script>' +
      '<script src="https://cdn.jsdelivr.net/npm/@zumer/snapdom@2.12.8/dist/snapdom.js"><\/script>' +
      '<style>@keyframes xpulse{0%,100%{opacity:.4}50%{opacity:1}}</style>';
    html = html.replace('</head>', head + '</head>');
    // VOILE opaque (cache l'affiche pendant toute la génération) + logique, avant </body>
    var over =
      '<div id="xover" style="position:fixed;inset:0;z-index:2147483647;background:#0a0e0c;color:#8a8576;' +
      'display:flex;align-items:center;justify-content:center;font:13px/1.5 ui-monospace,monospace;letter-spacing:.18em;">' +
      '<span style="animation:xpulse 1.6s ease-in-out infinite;">Génération du PDF…</span></div>';
    html = html.replace('</body>', over + '<script>' + exportLogic() + '<\/script></body>');
    document.open(); document.write(html); document.close();
  } catch (e) {
    document.getElementById('boot').textContent = 'Échec du chargement : ' + (e && e.message || e);
  }

  // logique d'export, sérialisée telle quelle dans le document réécrit
  function exportLogic() { return '(' + (function () {
    var W = 1024, H = 1448;   // canevas natif (ratio A4)
    var SCALE = 2.5;          // 1024×2.5 = 2560 px ≈ 309 DPI sur A4 (qualité print)
    var JPEG_Q = 0.95;
    var BAKE_TIMEOUT = 12000; // attente max de la « cuisson » de la carte de relief
    function wait(ms) { return new Promise(function (r) { setTimeout(r, ms); }); }
    function fail(m) { var o = document.getElementById('xover'); if (o) { o.style.animation = 'none'; o.style.opacity = 1; o.textContent = m; } }

    // La carte de relief (WebGL) se construit progressivement : on attend qu'elle soit
    // STABILISÉE (idle + tuiles chargées) avant de la « cuire » en PNG (#elevbake).
    async function waitMapSettled() {
      var elapsed = 0;
      while (!window.__emap && elapsed < BAKE_TIMEOUT) { await wait(200); elapsed += 200; }
      var m = window.__emap; if (!m) return false;
      var idleSeen = false; m.on('idle', function () { idleSeen = true; });
      while (elapsed < BAKE_TIMEOUT && !(idleSeen && m.areTilesLoaded && m.areTilesLoaded())) { await wait(250); elapsed += 250; }
      await wait(400); return true;
    }
    // bascule live → PNG cuit, appliquée seulement à la capture
    var swapStyle = document.createElement('style');
    swapStyle.textContent = '#elevmap{display:none!important;}#elevbake{display:block!important;}';

    async function run() {
      var poster = document.getElementById('poster');
      try {
        if (document.fonts && document.fonts.ready) { try { await document.fonts.ready; } catch (e) {} }
        var settled = await waitMapSettled();
        if (settled && typeof window.__bakeElev === 'function') {
          window.__bakeElev(); await wait(250);
          window.__bakeElev(); await wait(300);   // 2e cuisson = dernier état stabilisé
        }
        if (!swapStyle.parentNode) document.head.appendChild(swapStyle);
        await wait(120);

        var prev = poster.style.transform;
        poster.style.transform = 'none';
        var canvas = await window.snapdom.toCanvas(poster, {
          scale: SCALE, dpr: 1, embedFonts: true, backgroundColor: '#0f1412', width: W, height: H
        });
        poster.style.transform = prev;

        var data = canvas.toDataURL('image/jpeg', JPEG_Q);
        var pdf = new window.jspdf.jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4', compress: true });
        pdf.addImage(data, 'JPEG', 0, 0, 210, 297, undefined, 'FAST'); // plein cadre A4
        var url = pdf.output('bloburl');

        // remplace TOUT par le PDF (visionneuse du navigateur : impression / téléchargement)
        document.title = 'Affiche · Trail des Tectosages (PDF)';
        document.body.style.margin = '0';
        document.body.innerHTML = '<iframe title="Affiche - Trail des Tectosages" src="' + url +
          '" style="position:fixed;inset:0;width:100%;height:100%;border:0;background:#525659;"></iframe>';
      } catch (err) {
        console.error(err); fail('Échec : ' + (err && err.message || err) + ' — rechargez la page.');
      }
    }
    if (document.readyState === 'complete') run(); else window.addEventListener('load', run);
  }).toString() + ')();'; }
})();
</script>
</body>
</html>
