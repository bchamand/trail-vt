---
// Affiche imprimable A4 — page du site (synchronisée avec event.yaml + les courses).
// Les valeurs dynamiques (édition, lieu, dates, valeurs du Défi) viennent des données.
import { getEntry } from 'astro:content';
import { deriveEvent } from '../lib/event';
import { withBase } from '../lib/url';

const ev = await getEntry('event', 'main');
if (!ev) throw new Error('event.yaml: entrée "main" manquante');
const event = deriveEvent(ev.data);

// Date : jour + mois dérivés (le reste vient de deriveEvent : dateWeekday, year)
const fr = (opts: Intl.DateTimeFormatOptions) =>
  new Intl.DateTimeFormat('fr-FR', { timeZone: 'UTC', ...opts }).format(event.date);
const day = fr({ day: 'numeric' });
const month = fr({ month: 'long' }).toUpperCase();

// Kicker = valeurs des boucles du Défi de Copillos (article retiré, en majuscules).
// Se met à jour tout seul quand le Défi change (6 boucles → 4).
const defi = (await getEntry('races', 'defi-copillos'))?.data;
const kicker = (defi?.segments ?? []).map((s) =>
  s.label.replace(/^(l['’]|la |le |les )\s*/i, '').toUpperCase(),
);
const defiLoops = defi?.segments?.length ?? 0;
const defiKm = defi?.distance ? Math.round(defi.distance) : '';
const defiD = defi?.ascent ?? '';

const img = (name: string) => withBase(`/images/${name}`);
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Affiche · {event.name}</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css"/>
<script is:inline src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
<script is:inline src="https://unpkg.com/maplibre-contour@0.1.0/dist/index.min.js"></script>
<style is:global>
  :root{ --bg:#0f1412; --bg2:#0a0e0c; --ink:#e8e3d3; --gold:#d4a574; --gold-d:#b8915f; --olive:#9da36a; --muted:#8a8576; --line:rgba(232,227,211,0.16); }
  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{height:100%;background:#000;overflow:hidden;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  #stage{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:#000;}
  /* canevas au ratio A4 exact (210:297) → l'écran et le PDF sont identiques,
     l'impression se fait par mise à l'échelle uniforme (aucune déformation) */
  #poster{position:relative;width:1024px;height:1448px;flex:0 0 auto;transform-origin:center center;
    background:var(--bg);color:var(--ink);font-family:"JetBrains Mono",monospace;overflow:hidden;
    -webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .abs{position:absolute;}
  /* photo strata */
  .ph{position:absolute;z-index:1;}
  .ph img{display:block;width:100%;height:100%;object-fit:cover;filter:brightness(.84) contrast(1.07) saturate(.7) sepia(.16);}
  .ph .shade{position:absolute;inset:0;pointer-events:none;}
  /* cliff */
  #cliff{position:absolute;inset:0;z-index:2;
    background:
      radial-gradient(120% 80% at 12% 12%, rgba(40,46,40,.55), rgba(10,13,11,0) 60%),
      linear-gradient(105deg,#11160f 0%,#0c100c 46%,#161b13 60%,#0d1110 72%);}
  #cliffSvg{position:absolute;inset:0;z-index:2;pointer-events:none;}
  /* vraies courbes de niveau (MapLibre + maplibre-contour, DEM à la volée) en or, derrière le titre */
  #elevmap{position:absolute;inset:0;z-index:2;background:transparent;pointer-events:none;
    mix-blend-mode:screen;opacity:.6;
    -webkit-mask-image:radial-gradient(100% 60% at 23% 35%, #000 28%, rgba(0,0,0,.45) 60%, transparent 84%);
            mask-image:radial-gradient(100% 60% at 23% 35%, #000 28%, rgba(0,0,0,.45) 60%, transparent 84%);}
  /* version aplatie (masque cuit dans l'alpha du PNG) — utilisée à l'impression où Chrome ignore mask-image+blend sur le canvas WebGL */
  #elevbake{position:absolute;inset:0;z-index:2;width:100%;height:100%;pointer-events:none;opacity:.6;mix-blend-mode:screen;display:none;}
  @media print{ #elevmap{display:none!important;} #elevbake{display:block!important;} }
  #elevmap .maplibregl-map,#elevmap .maplibregl-canvas{background:transparent!important;}
  .maplibregl-ctrl-attribution{background:rgba(10,14,12,.5)!important;color:rgba(232,227,211,.4)!important;font-size:7px!important;}
  .maplibregl-ctrl-attribution a{color:rgba(212,165,116,.65)!important;}
  .maplibregl-ctrl-attribution.maplibregl-compact{min-height:20px;}
  #seams{position:absolute;inset:0;z-index:3;pointer-events:none;}
  .grain{position:absolute;inset:0;z-index:6;pointer-events:none;opacity:.05;mix-blend-mode:overlay;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='200' height='200' filter='url(%23n)'/%3E%3C/svg%3E");}
  .content{position:absolute;inset:0;z-index:5;}
  .mono{font-family:"JetBrains Mono",monospace;} .serif{font-family:"Instrument Serif",serif;}
  .gold{color:var(--gold);} .kick{font-family:"JetBrains Mono",monospace;letter-spacing:.36em;font-size:13px;color:var(--ink);}
  /* single-line TRAIL · typo site B (Instrument Serif) */
  .trail{font-family:"Instrument Serif",serif;font-weight:400;font-size:180px;line-height:.86;letter-spacing:.015em;
    color:#e8e3d3;filter:drop-shadow(0 4px 18px rgba(0,0,0,.6));}
  .parc{display:flex;align-items:flex-end;}
  .parc .cell{padding:0;border-left:none;flex:0 0 auto;}
  /* barres de séparation : items flex à part entière → pile au milieu des espaces */
  .parc .sep{width:1px;height:120px;background:var(--line);align-self:flex-end;}
  .parc .km{font-family:"Instrument Serif",serif;font-weight:400;font-size:60px;line-height:.78;color:var(--ink);white-space:nowrap;}
  .parc .u{font-family:"JetBrains Mono",monospace;font-weight:500;font-size:15px;letter-spacing:.12em;color:var(--gold);display:block;margin-top:6px;}
  .parc .d{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.1em;color:var(--muted);margin-top:12px;white-space:nowrap;}
  .parc .ptype{font-family:"JetBrains Mono",monospace;font-weight:600;font-size:8.5px;letter-spacing:.14em;color:var(--gold);display:block;margin-bottom:16px;white-space:nowrap;}
  .ico{stroke:var(--gold);fill:none;stroke-width:1.6;}
  a{color:inherit;text-decoration:none;}
  .vd{position:absolute;width:1px;background:var(--line);}
  .smallcap{font-family:"JetBrains Mono",monospace;font-weight:500;letter-spacing:.14em;}
  @media print{
    @page{ size:210mm 297mm; margin:0; }
    html,body{ width:210mm; height:297mm; background:#0f1412; overflow:hidden; }
    /* le clip se fait sur #stage (les moteurs d'impression ignorent parfois
       overflow:hidden sur body, ce qui créait une 2e page) */
    #stage{ position:relative; display:block; width:210mm; height:297mm; overflow:hidden; background:#0f1412; padding:0; }
    /* échelle d'impression en CSS pur, uniforme (canevas déjà au ratio A4 →
       zéro déformation) : l'affiche est CENTRÉE avec ~0,5mm de débord sur les
       QUATRE côtés — certains moteurs (PDF macOS notamment) décalent le
       contenu d'une fraction de mm, le débord symétrique absorbe ce décalage
       quel que soit son sens. !important pour battre le scale écran inline. */
    #poster{ position:absolute; left:50%; top:50%;
             transform-origin:center center !important;
             transform:translate(-50%,-50%) scale(0.779) !important; }
  }
</style>
</head>
<body>
<div id="stage">
  <div id="poster" data-screen-label="Affiche">
    <div class="ph pano"><img src={img('vue-clean.jpg')} alt="" style="transform:scale(1.34);transform-origin:56% 44%;"/><div class="shade" style="background:linear-gradient(180deg,rgba(10,14,12,.35),transparent 40%,transparent 70%,rgba(10,14,12,.55));"></div></div>
    <div class="ph forest"><img src={img('foret-clean.jpg')} alt="" style="transform:scale(1.06);transform-origin:54% 46%;"/><div class="shade" style="background:linear-gradient(100deg,rgba(10,14,12,.85) 4%,rgba(10,14,12,.2) 26%,transparent 50%);"></div></div>
    <div class="ph meadow"><img src={img('champ-clean.jpg')} alt="" style="transform:scale(1.42);transform-origin:34% 52%;"/><div class="shade" style="background:linear-gradient(95deg,rgba(10,14,12,.8) 2%,rgba(10,14,12,.15) 24%,transparent 46%),linear-gradient(0deg,rgba(10,14,12,.98) 0%,rgba(10,14,12,.62) 13%,rgba(10,14,12,.18) 30%,transparent 44%);"></div></div>

    <div id="cliff"></div>
    <div id="elevmap"></div>
    <svg id="cliffSvg" viewBox="0 0 1024 1536" preserveAspectRatio="none"></svg>
    <svg id="seams" viewBox="0 0 1024 1536" preserveAspectRatio="none"></svg>
    <div class="grain"></div>

    <div class="content">
      <!-- kicker · valeurs du Défi (dynamique) -->
      <div class="abs" style="left:60px;top:51px;line-height:2;">
        {kicker.map((v) => <div class="kick">{v}</div>)}
      </div>

      <!-- title · single line · typo site B · centré verticalement dans le creux -->
      <div class="abs" style="left:56px;top:334px;">
        <div style="display:flex;align-items:center;gap:14px;margin:0 0 24px 4px;white-space:nowrap;">
          <span style="display:inline-block;width:46px;height:1px;background:var(--gold);flex:0 0 auto;"></span>
          <span class="mono" style="font-size:14px;letter-spacing:.32em;color:var(--gold);font-weight:600;">ÉDITION&nbsp;{event.edition}</span>
        </div>
        <div class="trail">TRAIL</div>
        <div class="serif gold" style="font-style:italic;font-size:94px;line-height:1;margin-top:4px;white-space:nowrap;">des Tectosages</div>
        <div style="display:flex;align-items:center;gap:11px;margin-top:30px;">
          <svg class="ico" width="21" height="21" viewBox="0 0 24 24" style="stroke-width:1.7;"><path d="M12 21s7-6.4 7-12a7 7 0 0 0-14 0c0 5.6 7 12 7 12z"/><circle cx="12" cy="9" r="2.4"/></svg>
          <span class="mono" style="font-size:22px;letter-spacing:.16em;color:var(--ink);font-weight:600;white-space:nowrap;">{event.locationShort}</span>
        </div>
      </div>
      <!-- tagline (sous le titre) -->
      <div class="abs" style="left:60px;top:700px;">
        <div style="width:54px;height:1px;background:var(--gold);margin-bottom:24px;"></div>
        <div class="serif" style="font-style:italic;font-size:40px;line-height:1.1;color:rgba(232,227,211,.9);max-width:360px;">{event.tagline}</div>
      </div>

      <!-- bande info : date (1/3) + parcours & QR (2/3) -->
      <div class="abs" style="left:60px;right:60px;bottom:141px;display:flex;align-items:flex-end;">
        <div>
          <div class="mono" style="font-size:15px;letter-spacing:.46em;color:var(--gold);">{event.dateWeekday}</div>
          <div class="serif" style="font-size:148px;line-height:.74;margin-top:20px;">{day}</div>
          <div class="serif gold" style="font-size:58px;line-height:.9;letter-spacing:.04em;margin-top:18px;">{month}</div>
          <div class="mono" style="font-size:14px;letter-spacing:.5em;color:var(--muted);margin-top:20px;">{event.year}</div>
        </div>
        <div class="parc" style="margin-left:auto;width:66.666%;justify-content:space-between;">
          <div class="cell"><span class="ptype">TECTOKIDS</span><span class="km">1&ndash;3</span><span class="u">KM</span><div class="d">&nbsp;</div></div>
          <span class="sep"></span>
          <div class="cell"><span class="ptype">COURSES &amp; MARCHE</span><span class="km">5&ndash;10</span><span class="u">KM</span><div class="d">210&ndash;360 D+</div></div>
          <span class="sep"></span>
          <div class="cell"><span class="ptype">DÉFI &middot; {defiLoops} BOUCLES</span><span class="km">{defiKm}</span><span class="u">KM</span><div class="d">{defiD} D+</div></div>
          <div style="display:flex;flex-direction:column;align-items:center;gap:14px;">
            <a href={withBase('/')} target="_blank" rel="noopener" style="display:block;">
              <span style="background:#fff;border-radius:8px;padding:10px;display:block;"><img src={img('qr-trail-vt.png')} alt="QR inscriptions" style="width:104px;height:104px;display:block;"/></span>
            </a>
            <div style="text-align:center;">
              <div class="mono" style="font-size:10px;letter-spacing:.24em;color:var(--gold);line-height:1.8;">INFOS &amp;<br/>INSCRIPTIONS</div>
            </div>
          </div>
        </div>
      </div>

      <!-- ===== footer · zone partenaires ===== -->
      <div class="abs" style="left:60px;top:1333px;width:904px;border-top:1px solid var(--line);"></div>
      <div class="abs" style="left:60px;right:56px;top:1354px;display:flex;align-items:center;justify-content:space-between;gap:24px;">
        <!-- bénéficiaire (gauche) -->
        <div style="display:flex;align-items:center;gap:16px;">
          <span class="mono" style="font-size:10px;letter-spacing:.26em;color:var(--muted);white-space:nowrap;">AU&nbsp;PROFIT&nbsp;DE</span>
          <span style="background:#fff;border-radius:9px;width:172px;height:82px;display:flex;align-items:center;justify-content:center;padding:12px 16px;"><img src={img('logo-marie-louise-rect.png')} style="max-width:100%;max-height:100%;object-fit:contain;"/></span>
        </div>
        <!-- soutiens (droite) · cases plus larges pour les logos paysage (mairies) -->
        <div style="display:flex;align-items:center;gap:12px;">
          <span class="mono" style="font-size:10px;letter-spacing:.26em;color:var(--muted);white-space:nowrap;">AVEC&nbsp;LE&nbsp;SOUTIEN&nbsp;DE</span>
          <span style="background:#fff;border-radius:9px;width:150px;height:82px;display:flex;align-items:center;justify-content:center;padding:12px 16px;"><img src={img('logo-mairie-vieille-toulouse.png')} style="max-width:100%;max-height:100%;object-fit:contain;"/></span>
          <span style="background:#fff;border-radius:9px;width:112px;height:82px;display:flex;align-items:center;justify-content:center;padding:10px 14px;"><img src={img('logo-mairie-pechbusque.jpeg')} style="max-width:100%;max-height:100%;object-fit:contain;"/></span>
          <span style="background:#fff;border-radius:9px;width:82px;height:82px;display:flex;align-items:center;justify-content:center;padding:11px;"><img src={img('logo-lionsclubs.png')} style="max-width:100%;max-height:100%;object-fit:contain;"/></span>
          <span style="background:#fff;border-radius:9px;width:82px;height:82px;display:flex;align-items:center;justify-content:center;padding:11px;"><img src={img('logo-golf.png')} style="max-width:100%;max-height:100%;object-fit:contain;"/></span>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  // ---- geometry (1024 x 1536) ----
  var ridge=[[348,0],[366,90],[352,170],[404,260],[468,366],[520,474],[548,580],[558,684],[516,772],[446,858],[372,918],[330,986],[366,1086],[438,1188],[462,1176],[470,1198]];
  var panoSeam=[[404,260],[520,250],[660,232],[800,205],[1024,168]];
  var meadowSeam=[[349,1040],[540,966],[710,908],[882,856],[1024,812]];

  function poly(pts){ return 'polygon(' + pts.map(function(p){return (p[0]/1024*100).toFixed(2)+'% '+(p[1]/1536*100).toFixed(2)+'%';}).join(',') + ')'; }

  var cliffPts=[[0,0],[348,0]].concat(ridge).concat([[470,1198],[1024,1198],[1024,1536],[0,1536]]);
  var panoPts=[[348,0],[1024,0],[1024,168],[800,205],[660,232],[520,250],[404,260],[352,170],[366,90]];
  var forestPts=[[404,260],[520,250],[660,232],[800,205],[1024,168],[1024,812],[882,856],[710,908],[540,966],[349,1040],[330,986],[372,918],[446,858],[516,772],[558,684],[548,580],[520,474],[468,366]];
  var meadowPts=[[349,1040],[540,966],[710,908],[882,856],[1024,812],[1024,1198],[470,1198],[470,1184],[438,1188],[366,1086]];

  // géométrie dessinée en 1024×1536 ; le canevas réel est 1024×1448 (ratio A4)
  // → l'axe vertical est compressé de KY (les % des clip-path et les viewBox
  //   préservent les proportions relatives, seules les positions px changent)
  var KY=1448/1536;
  function place(sel,pts){var xs=pts.map(function(p){return p[0];}),ys=pts.map(function(p){return p[1];});var bx=Math.min.apply(null,xs),by=Math.min.apply(null,ys),bw=Math.max.apply(null,xs)-bx,bh=Math.max.apply(null,ys)-by;var e=document.querySelector(sel);e.style.left=bx+'px';e.style.top=(by*KY)+'px';e.style.width=bw+'px';e.style.height=(bh*KY)+'px';e.style.clipPath='polygon('+pts.map(function(p){return ((p[0]-bx)/bw*100).toFixed(2)+'% '+((p[1]-by)/bh*100).toFixed(2)+'%';}).join(',')+')';}
  place('.ph.pano',panoPts);
  place('.ph.forest',forestPts);
  place('.ph.meadow',meadowPts);
  document.getElementById('cliff').style.clipPath=poly(cliffPts);
  document.getElementById('cliffSvg').style.clipPath=poly(cliffPts);
  document.getElementById('elevmap').style.clipPath=poly(cliffPts);

  var SVGNS='http://www.w3.org/2000/svg';
  function el(n,a){var e=document.createElementNS(SVGNS,n);for(var k in a)e.setAttribute(k,a[k]);return e;}
  function ptsStr(p){return p.map(function(q){return q[0]+','+q[1];}).join(' ');}
  function offset(p,dx,dy){return p.map(function(q){return [q[0]+dx,q[1]+dy];});}

  // ---- vraies courbes de niveau d'altitude : MapLibre + maplibre-contour (DEM relief), centrées sur la colline de Vieille-Toulouse ----
  (function(){
    if(typeof maplibregl==='undefined'||typeof mlcontour==='undefined'){return;}
    var demSource=new mlcontour.DemSource({
      url:'https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png',
      encoding:'terrarium', maxzoom:15, worker:true
    });
    demSource.setupMaplibre(maplibregl);
    var map=new maplibregl.Map({
      container:'elevmap',
      interactive:false,
      attributionControl:false,
      preserveDrawingBuffer:true,
      center:[1.4575,43.5205],
      zoom:14.2,
      style:{
        version:8,
        sources:{
          contours:{
            type:'vector',
            tiles:[ demSource.contourProtocolUrl({
              thresholds:{11:[50,200],12:[20,100],13:[10,50],14:[10,50],15:[10,50]},
              overzoom:1, elevationKey:'ele', levelKey:'level', contourLayer:'contours'
            }) ],
            maxzoom:15
          }
        },
        layers:[
          {id:'minor',type:'line',source:'contours','source-layer':'contours',
           filter:['==',['get','level'],0],
           paint:{'line-color':'#7d5f37','line-width':0.7,'line-opacity':0.38}},
          {id:'major',type:'line',source:'contours','source-layer':'contours',
           filter:['==',['get','level'],1],
           paint:{'line-color':'#9c7a48','line-width':1.15,'line-opacity':0.55}}
        ]
      }
    });
    map.on('load',function(){ map.resize(); map.easeTo({center:[1.4575,43.5205], zoom:14.2, offset:[-290,-25], duration:0}); });
    window.__emap = map;

    // ---- aplatir les courbes masquées en PNG pour un export PDF fidèle (Chrome ignore mask-image+blend sur le canvas WebGL à l'impression) ----
    function bakeElev(){
      try{
        // Ne pas cuire si le conteneur est masqué/minuscule : sinon MapLibre
        // retombe sur un canvas 400×300 par défaut et la cuisson serait fausse,
        // écrasant la bonne version. Préserve la dernière bonne cuisson — vaut
        // pour l'impression (@media print) comme pour l'export PDF.
        var host=document.getElementById('elevmap');
        if(!host || host.offsetWidth < 100 || host.offsetHeight < 100) return;
        var src=map.getCanvas(); var w=src.width, h=src.height;
        if(!w||!h) return;
        var c=document.createElement('canvas'); c.width=w; c.height=h;
        var ctx=c.getContext('2d'); ctx.drawImage(src,0,0);
        // masque radial identique au CSS : 100% 60% at 23% 35%, stops 28%/60%/84%
        ctx.globalCompositeOperation='destination-in';
        var cx=0.23*w, cy=0.35*h, R=1.0*w;
        ctx.save(); ctx.translate(cx,cy); ctx.scale(1,(0.60*h)/R);
        var g=ctx.createRadialGradient(0,0,0,0,0,R);
        g.addColorStop(0,'rgba(0,0,0,1)'); g.addColorStop(0.28,'rgba(0,0,0,1)');
        g.addColorStop(0.60,'rgba(0,0,0,0.45)'); g.addColorStop(0.84,'rgba(0,0,0,0)');
        ctx.fillStyle=g; ctx.fillRect(-w*3,-h*3,w*6,h*6); ctx.restore();
        var img=document.getElementById('elevbake');
        if(!img){ img=document.createElement('img'); img.id='elevbake'; document.getElementById('elevmap').parentNode.insertBefore(img, document.getElementById('elevmap').nextSibling); }
        img.style.clipPath=document.getElementById('elevmap').style.clipPath;
        img.src=c.toDataURL('image/png');
      }catch(e){ /* canvas indisponible */ }
    }
    window.__bakeElev = bakeElev;   // exposé pour l'export PDF (cuisson à la demande)
    var bakeN=0, bakeTimer=setInterval(function(){ bakeElev(); if(++bakeN>=6) clearInterval(bakeTimer); }, 900);
    map.on('idle', bakeElev);
    window.addEventListener('beforeprint', bakeElev);
  })();

  // ---- séparations = courbes de niveau organiques (même langage que la carte d'altitude) ----
  (function(){
    var svg=document.getElementById('seams');
    function add(tag,attr){ var e=document.createElementNS(SVGNS,tag); for(var k in attr) e.setAttribute(k,attr[k]); svg.appendChild(e); return e; }
    function densify(pts,step){ var out=[]; for(var i=0;i<pts.length-1;i++){ var a=pts[i],b=pts[i+1],dx=b[0]-a[0],dy=b[1]-a[1],L=Math.hypot(dx,dy),n=Math.max(1,Math.round(L/step)); for(var j=0;j<n;j++) out.push([a[0]+dx*j/n,a[1]+dy*j/n]); } out.push(pts[pts.length-1]); return out; }
    function smooth(pts,passes){ for(var p=0;p<passes;p++){ var o=pts.slice(); for(var i=1;i<pts.length-1;i++){ o[i]=[(pts[i-1][0]+2*pts[i][0]+pts[i+1][0])/4,(pts[i-1][1]+2*pts[i][1]+pts[i+1][1])/4]; } pts=o; } return pts; }
    function arclen(pts){ var s=[0]; for(var i=1;i<pts.length;i++) s[i]=s[i-1]+Math.hypot(pts[i][0]-pts[i-1][0],pts[i][1]-pts[i-1][1]); return s; }
    function normals(pts){ var n=[]; for(var i=0;i<pts.length;i++){ var a=pts[Math.max(0,i-1)],b=pts[Math.min(pts.length-1,i+1)],dx=b[0]-a[0],dy=b[1]-a[1],L=Math.hypot(dx,dy)||1; n.push([dy/L,-dx/L]); } return n; }
    function noise(s,seed){ return Math.sin(s*0.012+seed*1.7)*0.55+Math.sin(s*0.026+seed*3.1)*0.30+Math.sin(s*0.052+seed*0.6)*0.15; }
    function toPath(pts){ if(pts.length<3) return 'M'+pts.map(function(p){return p[0].toFixed(1)+' '+p[1].toFixed(1);}).join(' L '); var d='M '+pts[0][0].toFixed(1)+' '+pts[0][1].toFixed(1); for(var i=0;i<pts.length-1;i++){ var p0=pts[i-1]||pts[i],p1=pts[i],p2=pts[i+1],p3=pts[i+2]||pts[i+1]; var c1x=p1[0]+(p2[0]-p0[0])/6,c1y=p1[1]+(p2[1]-p0[1])/6,c2x=p2[0]-(p3[0]-p1[0])/6,c2y=p2[1]-(p3[1]-p1[1])/6; d+=' C '+c1x.toFixed(1)+' '+c1y.toFixed(1)+' '+c2x.toFixed(1)+' '+c2y.toFixed(1)+' '+p2[0].toFixed(1)+' '+p2[1].toFixed(1); } return d; }
    function offPts(pts,nrm,s,d,seed,amp){ return pts.map(function(p,i){ var o=d+amp*noise(s[i],seed); return [p[0]+nrm[i][0]*o, p[1]+nrm[i][1]*o]; }); }
    var OFFS=[0,7,15,23,33,45,58], OPS=[0.5,0.36,0.28,0.2,0.14,0.1,0.06];
    function contourSeam(raw, side){
      var pts=smooth(densify(raw,8),1), s=arclen(pts), nrm=normals(pts);
      add('path',{d:toPath(pts),fill:'none',stroke:'rgba(9,12,10,0.7)','stroke-width':6,'stroke-linejoin':'round','stroke-linecap':'round'});
      for(var k=0;k<OFFS.length;k++){
        var pp=offPts(pts,nrm,s,OFFS[k]*side,k*1.37,3.2);
        add('path',{d:toPath(pp),fill:'none',stroke:'#d4a574','stroke-width':k===0?1.2:1,opacity:OPS[k],'stroke-linejoin':'round','stroke-linecap':'round'});
      }
    }
    var closeSeam=[[470,1198],[481,1207],[502,1210],[540,1210],[602,1207],[684,1201],[784,1193],[896,1186],[1024,1179]];
    contourSeam(panoSeam,-1);                          // pano / forêt
    contourSeam(meadowSeam,-1);                        // forêt / prairie
    contourSeam(ridge.concat(closeSeam.slice(1)),1);   // arête principale (autour du titre)
  })();

  function fit(){var p=document.getElementById('poster');p.style.transformOrigin='center center';var s=Math.min(window.innerWidth/1024,window.innerHeight/1448);p.style.transform='scale('+s+')';}
  window.addEventListener('resize',fit); fit();
  // (l'échelle d'impression est gérée en CSS pur dans @media print — fiable même
  //  quand le moteur d'impression n'émet pas l'évènement beforeprint)
</script>
</body>
</html>
