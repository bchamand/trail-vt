---
import { getCollection, getEntry } from 'astro:content';
import { join } from 'node:path';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import DataStrip from '../components/DataStrip.astro';
import Storytelling from '../components/Storytelling.astro';
import Races from '../components/Races.astro';
import type { RaceViewModel } from '../components/Races.astro';
import Banquet from '../components/Banquet.astro';
import PracticalInfo from '../components/PracticalInfo.astro';
import Supporters from '../components/Supporters.astro';
import Engagement from '../components/Engagement.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import { parseGpxFile } from '../lib/gpx';
import { withBase } from '../lib/url';
import { tileHosts } from '../lib/map-style';
import { deriveEvent, expandTokens, fmtKm, toRoman } from '../lib/event';
import '../styles/global.css';

const eventEntry = await getEntry('event', 'main');
if (!eventEntry) throw new Error('event.yaml: missing "main" entry');
const derived = deriveEvent(eventEntry.data);

const raceEntries = (await getCollection('races'))
  .filter(e => !e.data.hidden) // les épreuves « hidden: true » n'apparaissent pas
  .sort((a, b) => a.data.order - b.data.order);

// Distance et D+ : valeurs fournies dans le frontmatter en priorité, sinon
// calcul depuis le GPX. Pour une épreuve à boucles, le total = somme des
// boucles (chacune avec sa valeur fournie ou, à défaut, calculée du GPX).
const raceData = await Promise.all(
  raceEntries.map(async (entry, i) => {
    const d = entry.data;
    const gpxPath = join('public/traces', `${entry.id}.gpx`);
    const tracks = await parseGpxFile(gpxPath);

    const segments = d.segments?.map((seg, si) => ({
      ...seg,
      roman: toRoman(si + 1),
      distance: seg.distance ?? Math.round((tracks[si]?.totalDistance ?? 0) * 10) / 10,
      ascent: seg.ascent ?? Math.round(tracks[si]?.totalAscent ?? 0),
    }));

    const totalDistance = d.distance
      ?? (segments ? segments.reduce((s, seg) => s + seg.distance, 0)
                   : tracks.reduce((s, t) => s + t.totalDistance, 0));
    const totalAscent = d.ascent
      ?? (segments ? segments.reduce((s, seg) => s + seg.ascent, 0)
                   : tracks.reduce((s, t) => s + t.totalAscent, 0));

    const vm: RaceViewModel = {
      id: entry.id,
      order: d.order,
      roman: toRoman(i + 1),
      title: d.title,
      type: d.type,
      posterType: d.posterType,
      description: d.description,
      startTime: d.startTime,
      difficulty: d.difficulty,
      timed: d.timed,
      unit: d.unit,
      color: d.color,
      distanceDisplay: fmtKm(totalDistance),
      distanceDisplayInt: String(Math.floor(totalDistance)), // km tronqués pour le carrousel
      distanceKm: totalDistance, // distance officielle (override ?? somme boucles ?? GPX), pour l'axe du profil
      ascentDisplay: String(Math.round(totalAscent)),
      gpxUrl: withBase(`/traces/${entry.id}.gpx`),
      tracks,
      segments,
    };
    return { vm, distanceKm: totalDistance };
  })
);
const races: RaceViewModel[] = raceData.map(r => r.vm);
const maxDistance = Math.max(...raceData.map(r => r.distanceKm));

// Jetons utilisables dans toutes les chaînes d'event.yaml — voir ce fichier.
const tokens: Record<string, string> = {
  name: derived.name,
  edition: derived.edition,
  year: String(derived.year),
  dateFull: derived.dateFull,
  dateShort: derived.dateShort,
  dateShortMobile: derived.dateShortMobile,
  dateBadge: derived.dateBadge,
  dateWeekday: derived.dateWeekday,
  location: derived.location,
  locationCity: derived.locationCity,
  raceCount: toRoman(races.length),
  maxDistance: fmtKm(maxDistance),
  // En prod, le PDF de l'affiche est pré-généré par la CI (fichier statique) ;
  // en dev il n'existe pas, on pointe alors vers le générateur côté navigateur.
  affichePdf: import.meta.env.PROD ? '/affiche.pdf' : '/affiche/pdf',
  email: derived.urls.contactEmail,
};
const event = expandTokens(derived, tokens);

// Déroulé de la journée — généré automatiquement à partir des fiches :
// ouverture du point de rencontre + heure de départ de chaque épreuve visible
// + banquet, triés par heure. Modifier une fiche met à jour le déroulé.
const toMinutes = (s: string): number => {
  const m = String(s).match(/(\d{1,2})\s*h\s*(\d{0,2})/i);
  return m ? parseInt(m[1], 10) * 60 + (m[2] ? parseInt(m[2], 10) : 0) : 0;
};
const mp = event.practicalInfo.meetingPlace;
const scheduleSorted = [
  { time: mp.time, title: mp.scheduleLabel },
  ...races.map(r => ({ time: r.startTime, title: `Départ — ${r.title}` })),
  ...event.banquet.schedule,
].sort((a, b) => toMinutes(a.time) - toMinutes(b.time));
// masque l'heure quand elle est identique à la ligne précédente (lignes groupées)
const scheduleItems = scheduleSorted.map((it, i) => ({
  ...it,
  sameTime: i > 0 && toMinutes(it.time) === toMinutes(scheduleSorted[i - 1].time),
}));

const practicalInfo = {
  ...event.practicalInfo,
  schedule: { ...event.practicalInfo.schedule, items: scheduleItems },
};

const pageTitle = `${event.name} — ${event.location} · ${event.dateShort.toLowerCase()} ${event.year}`;
---
<Layout title={pageTitle} description={event.description} preconnect={tileHosts(event.mapStyle)}>
  <Nav event={event} />
  <Hero event={event} />
  <DataStrip stats={event.stats} />
  <Storytelling data={event.storytelling} />
  <Races races={races} section={event.racesSection} mapStyle={event.mapStyle} />
  <Banquet data={event.banquet} />
  <Engagement data={event.engagement} />
  <PracticalInfo data={practicalInfo} />
  <Supporters data={event.supporters} />
  <CTA data={event.cta} registrationUrl={event.urls.registration} />
  <Footer event={event} />
</Layout>
