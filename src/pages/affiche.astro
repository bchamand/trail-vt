---
// Affiche imprimable A4 — page du site (synchronisée avec event.yaml + les courses).
// Les valeurs dynamiques (édition, lieu, dates, valeurs du Défi) viennent des données.
import { getEntry, getCollection } from 'astro:content';
import { join } from 'node:path';
import { deriveEvent } from '../lib/event';
import { withBase } from '../lib/url';
import { parseGpxFile } from '../lib/gpx';
import QRCode from 'qrcode';
// Masques des photos : 1 SVG par photo dans src/affiche-masks/ (chacun déclare sa photo
// via data-photo, + cadrage data-scale/data-origin). Chargés tous, triés par nom de fichier.
// Zéro masque valide → l'affiche n'affiche ni photo, ni contour, ni séparation.
const maskModules = import.meta.glob('../affiche-masks/*.svg', { query: '?raw', import: 'default', eager: true });
const posterMasks = Object.keys(maskModules).sort().map((path, i) => {
  const svg = maskModules[path] as string;
  const m1 = svg.match(/data-photo\s*=\s*["']([^"']+)["']/);
  const m2 = svg.match(/data-scale\s*=\s*["']([^"']+)["']/);
  const m3 = svg.match(/data-origin\s*=\s*["']([^"']+)["']/);
  return { i, svg, photo: m1 ? m1[1] : '', scale: m2 ? m2[1] : '1', origin: m3 ? m3[1] : '50% 50%' };
}).filter((m) => m.photo);

const ev = await getEntry('event', 'main');
if (!ev) throw new Error('event.yaml: entrée "main" manquante');
const event = deriveEvent(ev.data);

// Date : jour + mois dérivés (le reste vient de deriveEvent : dateWeekday, year)
const fr = (opts: Intl.DateTimeFormatOptions) =>
  new Intl.DateTimeFormat('fr-FR', { timeZone: 'UTC', ...opts }).format(event.date);
const day = fr({ day: 'numeric' });
const month = fr({ month: 'long' }).toUpperCase();

// Kicker = valeurs des boucles du Défi de Copillos (article retiré, en majuscules).
// Se met à jour tout seul quand le Défi change (6 boucles → 4).
const defi = (await getEntry('races', 'defi-copillos'))?.data;
const kicker = (defi?.segments ?? []).map((s) =>
  s.label.replace(/^(l['’]|la |le |les )\s*/i, '').toUpperCase(),
);

// Courses montrées sur l'affiche : flag « poster », même ordre que le site (order).
// Distance et D+ : valeurs du frontmatter si présentes, sinon calculées depuis la
// trace GPX (public/traces/<id>.gpx) — exactement comme sur le site.
const posterEntries = (await getCollection('races'))
  .filter((r) => r.data.poster)
  .sort((a, b) => a.data.order - b.data.order);
const posterRaces = await Promise.all(posterEntries.map(async (r) => {
  const tracks = await parseGpxFile(join('public/traces', `${r.id}.gpx`));
  // Distance / D+ : valeur fournie en priorité, sinon somme des boucles
  // (chacune avec sa valeur fournie ou GPX), sinon calcul GPX direct.
  const segs = r.data.segments?.map((seg, si) => ({
    distance: seg.distance ?? (tracks[si]?.totalDistance ?? 0),
    ascent: seg.ascent ?? (tracks[si]?.totalAscent ?? 0),
  }));
  const dist = r.data.distance
    ?? (segs ? segs.reduce((s, x) => s + x.distance, 0) : tracks.reduce((s, t) => s + t.totalDistance, 0));
  const asc = r.data.ascent
    ?? (segs ? segs.reduce((s, x) => s + x.ascent, 0) : tracks.reduce((s, t) => s + t.totalAscent, 0));
  return {
    title: r.data.title,
    distance: dist ? String(Math.floor(dist)) : '', // tronqué à l'entier inférieur (40,1 → 40)
    unit: r.data.unit,
    ascent: asc ? String(Math.floor(asc / 100) * 100) : '', // arrondi à la centaine inférieure (1208 → 1200)
    posterType: r.data.posterType ?? '',
  };
}));

const img = (name: string) => withBase(`/images/${name}`);

// Logos partenaires : tirés de event.yaml (mêmes données que le site), avec leur
// taille d'affiche (posterWidth/posterPad). Ajouter/retirer un partenaire = un seul endroit.
const eng = event.engagement;
const posterPartners = event.supporters.partners;

// QR « Infos & inscriptions » : généré au build depuis l'adresse du site (event.urls.website)
// (SVG inline → net dans le PDF, plus aucune image à régénérer si l'adresse change).
const qrRaw = await QRCode.toString(event.urls.website, {
  type: 'svg', margin: 1, color: { dark: '#0f1412', light: '#ffffff' },
});
// taille fixe 128 px : on retire les dimensions par défaut du SVG et on fixe les nôtres
const qrSvg = qrRaw
  .replace(/\s(?:width|height)="[^"]*"/g, '')
  .replace('<svg', '<svg width="128" height="128" style="display:block"');

// L'affiche HTML sert à générer le PDF (en CI via /affiche/pdf) et au debug en dev.
// Elle n'est PAS déployée en prod : seul le PDF pré-généré (/affiche.pdf) y est public.
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Affiche · {event.name}</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css"/>
<script is:inline src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
<script is:inline src="https://unpkg.com/maplibre-contour@0.1.0/dist/index.min.js"></script>
<style is:global>
  :root{ --bg:#0f1412; --ink:#e8e3d3; --gold:#d4a574; --muted:#8a8576; --line:rgba(232,227,211,0.16); }
  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{height:100%;background:#000;overflow:hidden;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  #stage{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:#000;}
  /* canevas au ratio A4 exact (210:297) → l'écran et le PDF sont identiques,
     l'impression se fait par mise à l'échelle uniforme (aucune déformation) */
  #poster{position:relative;width:1024px;height:1448px;flex:0 0 auto;transform-origin:center center;
    background:var(--bg);color:var(--ink);font-family:"JetBrains Mono",monospace;overflow:hidden;
    -webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .abs{position:absolute;}
  /* photo strata */
  .ph{position:absolute;z-index:3;}
  .ph img{display:block;width:100%;height:100%;object-fit:cover;filter:brightness(.84) contrast(1.07) saturate(.7);}
  /* fondu générique : assombrit le bord gauche (vers le titre) + un peu le bas */
  .ph .shade{position:absolute;inset:0;pointer-events:none;
    background:linear-gradient(100deg,rgba(10,14,12,.82) 3%,rgba(10,14,12,.18) 25%,transparent 47%),
               linear-gradient(0deg,rgba(10,14,12,.5) 0%,transparent 20%);}
  /* cliff */
  #cliff{position:absolute;inset:0;z-index:2;
    background:
      radial-gradient(120% 80% at 12% 12%, rgba(40,46,40,.55), rgba(10,13,11,0) 60%),
      linear-gradient(105deg,#11160f 0%,#0c100c 46%,#161b13 60%,#0d1110 72%);}
  /* vraies courbes de niveau (MapLibre + maplibre-contour, DEM à la volée) en or, derrière le titre */
  #elevmap{position:absolute;inset:0;z-index:2;background:transparent;pointer-events:none;
    mix-blend-mode:screen;opacity:.6;
    -webkit-mask-image:radial-gradient(120% 70% at 23% 35%, #000 28%, rgba(0,0,0,.45) 60%, transparent 84%);
            mask-image:radial-gradient(120% 70% at 23% 35%, #000 28%, rgba(0,0,0,.45) 60%, transparent 84%);}
  /* version aplatie (masque cuit dans l'alpha du PNG) — utilisée à l'impression où Chrome ignore mask-image+blend sur le canvas WebGL */
  #elevbake{position:absolute;inset:0;z-index:2;width:100%;height:100%;pointer-events:none;opacity:.6;mix-blend-mode:screen;display:none;}
  @media print{ #elevmap{display:none!important;} #elevbake{display:block!important;} }
  #elevmap .maplibregl-map,#elevmap .maplibregl-canvas{background:transparent!important;}
  .maplibregl-ctrl-attribution{background:rgba(10,14,12,.5)!important;color:rgba(232,227,211,.4)!important;font-size:7px!important;}
  .maplibregl-ctrl-attribution a{color:rgba(212,165,116,.65)!important;}
  .maplibregl-ctrl-attribution.maplibregl-compact{min-height:20px;}
  #seams{position:absolute;inset:0;z-index:4;pointer-events:none;}
  .grain{position:absolute;inset:0;z-index:6;pointer-events:none;opacity:.05;mix-blend-mode:overlay;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='200' height='200' filter='url(%23n)'/%3E%3C/svg%3E");}
  .content{position:absolute;inset:0;z-index:5;}
  .mono{font-family:"JetBrains Mono",monospace;} .serif{font-family:"Instrument Serif",serif;}
  .gold{color:var(--gold);} .kick{font-family:"JetBrains Mono",monospace;letter-spacing:.36em;font-size:13px;color:var(--ink);}
  /* single-line TRAIL · typo site B (Instrument Serif) */
  .trail{font-family:"Instrument Serif",serif;font-weight:400;font-size:180px;line-height:.86;letter-spacing:.015em;
    color:#e8e3d3;filter:drop-shadow(0 4px 18px rgba(0,0,0,.6));}
  .parc{display:flex;align-items:flex-end;}
  /* 3 colonnes ÉGALES dans les 2/3 : 2 boucles + QR */
  .parc .cell{padding:0;flex:1 1 0;min-width:0;}
  /* espace entre les cases du bandeau info = 2× le gap des logos → 28px : barre de 1px +
     13.5px de marge de chaque côté → barre centrée. .ghost = même espace mais SANS barre (boucle ↔ QR) */
  .parc .sep{flex:0 0 1px;height:160px;background:var(--line);align-self:flex-end;margin:0 13.5px;}
  .parc .sep.ghost{background:none;}
  /* le QR prend sa largeur propre (dérivée de sa hauteur) ; les 2 courses se partagent le reste */
  .parc .qrcell{flex:0 0 auto;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:16px;}
  .parc .km{font-family:"Instrument Serif",serif;font-weight:400;font-size:72px;line-height:.78;color:var(--ink);white-space:nowrap;}
  .parc .u{font-family:"JetBrains Mono",monospace;font-weight:500;font-size:20px;letter-spacing:.12em;color:var(--gold);display:block;margin-top:8px;}
  .parc .d{font-family:"JetBrains Mono",monospace;font-size:16px;letter-spacing:.1em;color:var(--muted);margin-top:16px;white-space:nowrap;}
  /* nom de la course (haut de la cellule) et « type de course » (bas) */
  .parc .rname{font-family:"JetBrains Mono",monospace;font-weight:600;font-size:15px;letter-spacing:.05em;color:var(--gold);display:block;margin-bottom:18px;line-height:1.3;}
  .parc .rtype{font-family:"JetBrains Mono",monospace;font-weight:500;font-size:12px;letter-spacing:.02em;color:rgba(232,227,211,.6);margin-top:14px;line-height:1.35;white-space:nowrap;}
  .ico{stroke:var(--gold);fill:none;stroke-width:1.6;}
  a{color:inherit;text-decoration:none;}
  @media print{
    @page{ size:210mm 297mm; margin:0; }
    html,body{ width:210mm; height:297mm; background:#0f1412; overflow:hidden; }
    /* le clip se fait sur #stage (les moteurs d'impression ignorent parfois
       overflow:hidden sur body, ce qui créait une 2e page) */
    #stage{ position:relative; display:block; width:210mm; height:297mm; overflow:hidden; background:#0f1412; padding:0; }
    /* échelle d'impression en CSS pur, uniforme (canevas déjà au ratio A4 →
       zéro déformation) : l'affiche est CENTRÉE avec ~0,5mm de débord sur les
       QUATRE côtés — certains moteurs (PDF macOS notamment) décalent le
       contenu d'une fraction de mm, le débord symétrique absorbe ce décalage
       quel que soit son sens. !important pour battre le scale écran inline. */
    #poster{ position:absolute; left:50%; top:50%;
             transform-origin:center center !important;
             transform:translate(-50%,-50%) scale(0.779) !important; }
  }
</style>
</head>
<body>
<!-- masques des photos (src/affiche-masks/*.svg) injectés, invisibles : source géométrique de chaque photo -->
{posterMasks.map((m) => (
  <div class="mask-src" data-i={m.i} aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden;pointer-events:none;" set:html={m.svg}></div>
))}
<div id="stage">
  <div id="poster" data-screen-label="Affiche">
    {posterMasks.map((m) => (
      <div class="ph" data-i={m.i}><img src={img(m.photo)} alt="" style={`object-position:${m.origin};transform:scale(${m.scale});transform-origin:${m.origin};`}/><div class="shade"></div></div>
    ))}

    <div id="cliff"></div>
    <div id="elevmap"></div>
    <svg id="seams" viewBox="0 0 1024 1448" preserveAspectRatio="none"></svg>
    <div class="grain"></div>

    <div class="content">
      <!-- kicker · valeurs du Défi (dynamique) -->
      <div class="abs" style="left:60px;top:51px;line-height:2;">
        {kicker.map((v) => <div class="kick">{v}</div>)}
      </div>

      <!-- title · single line · typo site B · centré verticalement dans le creux -->
      <div class="abs" style="left:56px;top:298px;">
        <div style="display:flex;align-items:center;gap:14px;margin:0 0 24px 4px;white-space:nowrap;">
          <span style="display:inline-block;width:46px;height:1px;background:var(--gold);flex:0 0 auto;"></span>
          <span class="mono" style="font-size:14px;letter-spacing:.32em;color:var(--gold);font-weight:600;">ÉDITION&nbsp;{event.edition}</span>
        </div>
        <div class="trail">TRAIL</div>
        <div class="serif gold" style="font-style:italic;font-size:94px;line-height:1;margin-top:4px;white-space:nowrap;">des Tectosages</div>
        <div style="display:flex;align-items:center;gap:11px;margin-top:30px;">
          <svg class="ico" width="21" height="21" viewBox="0 0 24 24" style="stroke-width:1.7;"><path d="M12 21s7-6.4 7-12a7 7 0 0 0-14 0c0 5.6 7 12 7 12z"/><circle cx="12" cy="9" r="2.4"/></svg>
          <span class="mono" style="font-size:22px;letter-spacing:.16em;color:var(--ink);font-weight:600;white-space:nowrap;">{event.locationShort}</span>
        </div>
      </div>
      <!-- tagline (sous le titre) -->
      <div class="abs" style="left:60px;top:664px;">
        <div style="width:54px;height:1px;background:var(--gold);margin-bottom:24px;"></div>
        <div class="serif" style="font-style:italic;font-size:40px;line-height:1.1;color:rgba(232,227,211,.9);max-width:360px;">{event.tagline}</div>
      </div>

      <!-- bande info : date (1/3) + (2 boucles + QR à égalité) (2/3) -->
      <div class="abs" style="left:60px;right:60px;bottom:214px;display:flex;align-items:flex-end;">
        <div style="flex:0 0 33.333%;">
          <div class="mono" style="font-size:18px;letter-spacing:.46em;color:var(--gold);">{event.dateWeekday}</div>
          <div class="serif" style="font-size:150px;line-height:.74;margin-top:20px;">{day}</div>
          <div class="serif gold" style="font-size:64px;line-height:.9;letter-spacing:.04em;margin-top:18px;">{month}</div>
          <div class="mono" style="font-size:17px;letter-spacing:.5em;color:var(--muted);margin-top:20px;">{event.year}</div>
        </div>
        <div class="parc" style="flex:0 0 66.667%;">
          {posterRaces.map((r, i) => (
            <>
              {i > 0 && <span class="sep"></span>}
              <div class="cell">
                <span class="rname">{r.title}</span>
                <span class="km">{r.distance}</span><span class="u">{r.unit}</span>
                <div class="d">{r.ascent} D+</div>
                {r.posterType && <div class="rtype">{r.posterType}</div>}
              </div>
            </>
          ))}
          <span class="sep ghost"></span>
          <div class="cell qrcell">
            <a href={withBase('/')} target="_blank" rel="noopener" style="display:block;">
              <span style="background:#fff;border-radius:9px;padding:12px;display:block;" set:html={qrSvg}></span>
            </a>
            <div class="mono qrtext" style="font-size:13px;letter-spacing:.2em;color:var(--gold);line-height:1.7;text-align:center;">INFOS&nbsp;&amp;<br/>INSCRIPTIONS</div>
          </div>
        </div>
      </div>

      <!-- ===== footer · zone partenaires (agrandie pour l'impression A5) ===== -->
      <div class="abs" style="left:60px;right:60px;bottom:186px;border-top:1px solid var(--line);"></div>
      <div class="abs" style="left:60px;right:56px;bottom:24px;display:flex;align-items:flex-start;justify-content:space-between;gap:28px;">
        <!-- bénéficiaire : logo « au profit de » (engagement.posterLogo) -->
        <div style="display:flex;flex-direction:column;align-items:flex-start;gap:16px;">
          <span class="mono" style="font-size:14px;letter-spacing:.26em;color:var(--muted);white-space:nowrap;">AU&nbsp;PROFIT&nbsp;DE</span>
          {eng.posterLogo && (
            <span style={`background:#fff;border-radius:12px;width:${eng.posterWidth ?? 200}px;height:114px;display:flex;align-items:center;justify-content:center;padding:${eng.posterPad ?? '16px'};`}><img src={withBase(eng.posterLogo)} alt={eng.logoAlt} style="max-width:100%;max-height:100%;object-fit:contain;"/></span>
          )}
        </div>
        <!-- soutiens : logos itérés depuis supporters.partners (même source que le site) -->
        <div style="display:flex;flex-direction:column;align-items:flex-start;gap:16px;">
          <span class="mono" style="font-size:14px;letter-spacing:.26em;color:var(--muted);white-space:nowrap;">AVEC&nbsp;LE&nbsp;SOUTIEN&nbsp;DE</span>
          <div style="display:flex;align-items:center;gap:14px;">
            {posterPartners.map((p) => (
              <span style={`background:#fff;border-radius:12px;width:${p.posterWidth ?? 130}px;height:114px;display:flex;align-items:center;justify-content:center;padding:${p.posterPad ?? '14px'};`}><img src={withBase(p.logo)} alt={`${p.name} ${p.sub}`} style="max-width:100%;max-height:100%;object-fit:contain;"/></span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  // ---- masques des photos : 1 région fermée par photo (src/affiche-masks/*.svg) ----
  // Chaque photo se détoure EXACTEMENT sur sa région ; les contours dorés et le fond
  // en sont dérivés. Aucun masque → aucune photo, aucun contour, aucune séparation.
  // échantillonne une forme SVG (polygon/polyline/path) en points, dans le repère du viewBox
  function readShape(el){ if(!el||!el.getTotalLength) return []; var L=el.getTotalLength(), n=Math.max(3,Math.round(L/8)), out=[]; for(var i=0;i<=n;i++){ var p=el.getPointAtLength(L*i/n); out.push([p.x,p.y]); } return out; }
  // lissage organique PARTAGÉ : détourage des photos ET contours dorés = la même courbe lissée
  function densify(pts,step){ var out=[]; for(var i=0;i<pts.length-1;i++){ var a=pts[i],b=pts[i+1],dx=b[0]-a[0],dy=b[1]-a[1],L=Math.hypot(dx,dy),n=Math.max(1,Math.round(L/step)); for(var j=0;j<n;j++) out.push([a[0]+dx*j/n,a[1]+dy*j/n]); } out.push(pts[pts.length-1]); return out; }
  function smooth(pts,passes){ for(var p=0;p<passes;p++){ var o=pts.slice(); for(var i=1;i<pts.length-1;i++){ o[i]=[(pts[i-1][0]+2*pts[i][0]+pts[i+1][0])/4,(pts[i-1][1]+2*pts[i][1]+pts[i+1][1])/4]; } pts=o; } return pts; }
  // accroche au cadre les points proches d'un bord (le lissage rabote sinon les coins
  // région↔cadre → bords droits préservés et détection de bord fiable)
  function snapEdge(p){ var x=p[0],y=p[1]; if(x<8)x=0; else if(x>1016)x=1024; if(y<8)y=0; else if(y>1440)y=1448; return [x,y]; }
  function smoothLine(line){ return line.length<3 ? line : smooth(densify(line,8),1).map(snapEdge); }

  // le masque est déjà dans le repère du poster (1024×1448, format A4) → placement 1:1, aucune compression
  function place(el,pts){ var xs=pts.map(function(p){return p[0];}),ys=pts.map(function(p){return p[1];}); var bx=Math.min.apply(null,xs),by=Math.min.apply(null,ys),bw=Math.max.apply(null,xs)-bx,bh=Math.max.apply(null,ys)-by; el.style.left=bx+'px'; el.style.top=by+'px'; el.style.width=bw+'px'; el.style.height=bh+'px'; el.style.clipPath='polygon('+pts.map(function(p){return ((p[0]-bx)/bw*100).toFixed(2)+'% '+((p[1]-by)/bh*100).toFixed(2)+'%';}).join(',')+')'; }

  // lit chaque masque injecté → région lissée, place la photo correspondante, mémorise la région
  var REGIONS=[];
  [].forEach.call(document.querySelectorAll('.mask-src'), function(holder){
    var shape=holder.querySelector('polygon,polyline,path'); if(!shape) return;
    var region=smoothLine(readShape(shape)); if(region.length<3) return;
    var photo=document.querySelector('.ph[data-i="'+holder.getAttribute('data-i')+'"]');
    if(photo) place(photo,region);
    REGIONS.push(region);
  });

  // Fond sombre : #cliff remplit tout le canevas, les photos passent par-dessus (z-index).
  // Relief (courbes d'altitude) : AUCUN détourage — il s'estompe via son seul masque radial
  // (CSS à l'écran, cuit dans le PNG à l'impression), et les photos le recouvrent là où elles
  // sont. Il reste donc continu et indépendant des masques (plus de coupure « masque fantôme »).

  // le QR (cadre blanc + libellé) est ramené à la MÊME HAUTEUR qu'une cellule de boucle
  function sizeQR(){
    var cell=document.querySelector('.parc .cell:not(.qrcell)'), svg=document.querySelector('.qrcell svg'), txt=document.querySelector('.qrtext');
    if(!cell||!svg||!txt) return;
    var s=Math.round(cell.offsetHeight - 24 - 16 - txt.offsetHeight);   // 24 = cadre blanc (2×12px), 16 = gap QR/texte
    if(s>60){ svg.style.width=s+'px'; svg.style.height=s+'px'; }
  }
  (function(){
    var cell=document.querySelector('.parc .cell:not(.qrcell)');
    // recalcule quand la cellule se stabilise (chargement des polices, reflow) — sinon sizeQR
    // tournerait trop tôt sur une hauteur transitoire
    if(cell && window.ResizeObserver) new ResizeObserver(sizeQR).observe(cell);
    if(document.fonts&&document.fonts.ready) document.fonts.ready.then(sizeQR);
    sizeQR();
  })();

  var SVGNS='http://www.w3.org/2000/svg';   // utilisé par le tracé des contours dorés (#seams)

  // ---- vraies courbes de niveau d'altitude : MapLibre + maplibre-contour (DEM relief), centrées sur la colline de Vieille-Toulouse ----
  (function(){
    if(typeof maplibregl==='undefined'||typeof mlcontour==='undefined'){return;}
    var demSource=new mlcontour.DemSource({
      url:'https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png',
      encoding:'terrarium', maxzoom:15, worker:true
    });
    demSource.setupMaplibre(maplibregl);
    var map=new maplibregl.Map({
      container:'elevmap',
      interactive:false,
      attributionControl:false,
      preserveDrawingBuffer:true,
      center:[1.4575,43.5205],
      zoom:14.2,
      style:{
        version:8,
        sources:{
          contours:{
            type:'vector',
            tiles:[ demSource.contourProtocolUrl({
              thresholds:{11:[50,200],12:[20,100],13:[10,50],14:[10,50],15:[10,50]},
              overzoom:1, elevationKey:'ele', levelKey:'level', contourLayer:'contours'
            }) ],
            maxzoom:15
          }
        },
        layers:[
          {id:'minor',type:'line',source:'contours','source-layer':'contours',
           filter:['==',['get','level'],0],
           paint:{'line-color':'#7d5f37','line-width':0.7,'line-opacity':0.38}},
          {id:'major',type:'line',source:'contours','source-layer':'contours',
           filter:['==',['get','level'],1],
           paint:{'line-color':'#9c7a48','line-width':1.15,'line-opacity':0.55}}
        ]
      }
    });
    map.on('load',function(){ map.resize(); map.easeTo({center:[1.4575,43.5205], zoom:14.2, offset:[-290,-25], duration:0}); });
    window.__emap = map;

    // ---- aplatir les courbes masquées en PNG pour un export PDF fidèle (Chrome ignore mask-image+blend sur le canvas WebGL à l'impression) ----
    function bakeElev(){
      try{
        // Ne pas cuire si le conteneur est masqué/minuscule : sinon MapLibre
        // retombe sur un canvas 400×300 par défaut et la cuisson serait fausse,
        // écrasant la bonne version. Préserve la dernière bonne cuisson — vaut
        // pour l'impression (@media print) comme pour l'export PDF.
        var host=document.getElementById('elevmap');
        if(!host || host.offsetWidth < 100 || host.offsetHeight < 100) return;
        var src=map.getCanvas(); var w=src.width, h=src.height;
        if(!w||!h) return;
        var c=document.createElement('canvas'); c.width=w; c.height=h;
        var ctx=c.getContext('2d'); ctx.drawImage(src,0,0);
        // masque radial identique au CSS : 120% 70% at 23% 35%, stops 28%/60%/84%
        ctx.globalCompositeOperation='destination-in';
        var cx=0.23*w, cy=0.35*h, R=1.2*w;
        ctx.save(); ctx.translate(cx,cy); ctx.scale(1,(0.70*h)/R);
        var g=ctx.createRadialGradient(0,0,0,0,0,R);
        g.addColorStop(0,'rgba(0,0,0,1)'); g.addColorStop(0.28,'rgba(0,0,0,1)');
        g.addColorStop(0.60,'rgba(0,0,0,0.45)'); g.addColorStop(0.84,'rgba(0,0,0,0)');
        ctx.fillStyle=g; ctx.fillRect(-w*3,-h*3,w*6,h*6); ctx.restore();
        var img=document.getElementById('elevbake');
        if(!img){ img=document.createElement('img'); img.id='elevbake'; document.getElementById('elevmap').parentNode.insertBefore(img, document.getElementById('elevmap').nextSibling); }
        img.style.clipPath=document.getElementById('elevmap').style.clipPath;
        img.src=c.toDataURL('image/png');
      }catch(e){ /* canvas indisponible */ }
    }
    window.__bakeElev = bakeElev;   // exposé pour l'export PDF (cuisson à la demande)
    var bakeN=0, bakeTimer=setInterval(function(){ bakeElev(); if(++bakeN>=6) clearInterval(bakeTimer); }, 900);
    map.on('idle', bakeElev);
    window.addEventListener('beforeprint', bakeElev);
  })();

  // ---- séparations = courbes de niveau organiques (même langage que la carte d'altitude) ----
  (function(){
    var svg=document.getElementById('seams');
    function add(tag,attr){ var e=document.createElementNS(SVGNS,tag); for(var k in attr) e.setAttribute(k,attr[k]); svg.appendChild(e); return e; }
    function normals(pts){ var n=[]; for(var i=0;i<pts.length;i++){ var a=pts[Math.max(0,i-1)],b=pts[Math.min(pts.length-1,i+1)],dx=b[0]-a[0],dy=b[1]-a[1],L=Math.hypot(dx,dy)||1; n.push([dy/L,-dx/L]); } return n; }
    function toPath(pts){ if(pts.length<3) return 'M'+pts.map(function(p){return p[0].toFixed(1)+' '+p[1].toFixed(1);}).join(' L '); var d='M '+pts[0][0].toFixed(1)+' '+pts[0][1].toFixed(1); for(var i=0;i<pts.length-1;i++){ var p0=pts[i-1]||pts[i],p1=pts[i],p2=pts[i+1],p3=pts[i+2]||pts[i+1]; var c1x=p1[0]+(p2[0]-p0[0])/6,c1y=p1[1]+(p2[1]-p0[1])/6,c2x=p2[0]-(p3[0]-p1[0])/6,c2y=p2[1]-(p3[1]-p1[1])/6; d+=' C '+c1x.toFixed(1)+' '+c1y.toFixed(1)+' '+c2x.toFixed(1)+' '+c2y.toFixed(1)+' '+p2[0].toFixed(1)+' '+p2[1].toFixed(1); } return d; }
    function offPts(pts,nrm,d){ return pts.map(function(p,i){ return [p[0]+nrm[i][0]*d, p[1]+nrm[i][1]*d]; }); }
    // éventail SERRÉ et SANS bruit → les lignes dorées épousent précisément l'arête lissée du masque
    var OFFS=[0,4,9,15], OPS=[0.62,0.42,0.26,0.13];
    function contourSeam(pts, side){
      var nrm=normals(pts);   // pts déjà lissés = mêmes points que le détourage des photos
      add('path',{d:toPath(pts),fill:'none',stroke:'rgba(9,12,10,0.7)','stroke-width':4,'stroke-linejoin':'round','stroke-linecap':'round'});
      for(var k=0;k<OFFS.length;k++){
        var pp=offPts(pts,nrm,OFFS[k]*side);
        add('path',{d:toPath(pp),fill:'none',stroke:'#d4a574','stroke-width':k===0?1.5:1,opacity:OPS[k],'stroke-linejoin':'round','stroke-linecap':'round'});
      }
    }
    // contours dorés sur les bords ORGANIQUES (hors cadre du poster) de chaque région.
    // Chaque photo évase ses lignes de niveau vers son intérieur → la séparation, bord
    // commun aux 2 photos, est habillée symétriquement de part et d'autre.
    function borderEdge(a,b){ return (a[0]<=1&&b[0]<=1)||(a[0]>=1023&&b[0]>=1023)||(a[1]<=1&&b[1]<=1)||(a[1]>=1447&&b[1]>=1447); }
    function isCW(p){ var s=0; for(var i=0;i<p.length-1;i++) s+=(p[i+1][0]-p[i][0])*(p[i+1][1]+p[i][1]); return s>0; }
    REGIONS.forEach(function(region){
      var ring = isCW(region) ? region.slice().reverse() : region;   // CCW → intérieur à gauche
      var run=[];
      function flush(){ if(run.length>=2) contourSeam(run,-1); run=[]; }   // -1 = éventail vers l'intérieur (la photo)
      for(var i=0;i<ring.length-1;i++){
        var a=ring[i], b=ring[i+1];
        if(borderEdge(a,b)){ flush(); continue; }
        if(!run.length) run.push(a);
        run.push(b);
      }
      flush();
    });
  })();

  function fit(){var p=document.getElementById('poster');p.style.transformOrigin='center center';var s=Math.min(window.innerWidth/1024,window.innerHeight/1448);p.style.transform='scale('+s+')';}
  window.addEventListener('resize',fit); fit();
  // (l'échelle d'impression est gérée en CSS pur dans @media print — fiable même
  //  quand le moteur d'impression n'émet pas l'évènement beforeprint)
</script>
</body>
</html>
